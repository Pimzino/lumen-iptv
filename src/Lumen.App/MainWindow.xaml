<Window x:Class="Lumen.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:Lumen.App.Controls"
        xmlns:res="clr-namespace:Lumen.App.Resources"
        xmlns:svc="clr-namespace:Lumen.App.Services"
        xmlns:theming="clr-namespace:Lumen.App.Theming"
        Title="{x:Static res:Strings.App_Title}"
        Width="1280"
        Height="768"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

  <!-- Immersive (borderless, taskbar-covering) chrome is applied in code-behind only for TRUE
       fullscreen — not the windowed full player, which keeps its window controls (in the player bar). -->
  <Window.Style>
    <Style TargetType="Window" BasedOn="{StaticResource Lumen.Window}" />
  </Window.Style>

  <ctl:LumenChrome.TitleBarContent>
    <Button Style="{StaticResource Lumen.SearchBox.Shell}"
            Content="{x:Static res:Strings.Shell_SearchPlaceholder}"
            Command="{Binding NavigateCommand}"
            CommandParameter="search"
            Visibility="{Binding IsShellReady, Converter={StaticResource Lumen.BoolToVisibility}}"
            AutomationProperties.Name="{x:Static res:Strings.Nav_Search}" />
  </ctl:LumenChrome.TitleBarContent>

  <Window.InputBindings>
    <KeyBinding Modifiers="Control" Key="K"
                Command="{Binding NavigateCommand}"
                CommandParameter="search" />
  </Window.InputBindings>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ======================= Navigation rail ======================= -->
    <Border x:Name="Rail"
            Grid.Column="0"
            Width="72"
            Visibility="{Binding IsShellReady, Converter={StaticResource Lumen.BoolToVisibility}}">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsRailExpanded}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     To="240"
                                     Duration="{theming:Dur Slow}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                     To="72"
                                     Duration="{theming:Dur Slow}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>

      <DockPanel LastChildFill="True">
        <Button DockPanel.Dock="Top"
                Style="{StaticResource Lumen.Button.Icon}"
                Content="{StaticResource Lumen.Icon.Menu}"
                Command="{Binding ToggleRailCommand}"
                HorizontalAlignment="Left"
                Margin="18,8,0,8"
                AutomationProperties.Name="{x:Static res:Strings.Shell_Menu}" />

        <StackPanel DockPanel.Dock="Bottom">
          <Button x:Name="ProfileChip"
                  Style="{StaticResource Lumen.ProfileChip}"
                  Command="{Binding OpenProfileFlyoutCommand}"
                  AutomationProperties.Name="{x:Static res:Strings.Shell_Profiles}" />
          <Popup PlacementTarget="{Binding ElementName=ProfileChip}"
                 Placement="Top"
                 VerticalOffset="-8"
                 HorizontalOffset="8"
                 AllowsTransparency="True"
                 StaysOpen="False"
                 PopupAnimation="None"
                 IsOpen="{Binding IsProfileFlyoutOpen, Mode=TwoWay}">
            <Border Background="{StaticResource Lumen.Brush.Glass}"
                    BorderBrush="{StaticResource Lumen.Brush.Stroke.Glass}"
                    BorderThickness="{StaticResource Lumen.Stroke.Border}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}"
                    Padding="{StaticResource Lumen.Pad.8}"
                    MinWidth="240">
              <StackPanel>
                <TextBlock Style="{StaticResource Lumen.Text.Micro}"
                           Text="{x:Static res:Strings.Shell_Profiles}"
                           Margin="12,8,12,8" />
                <ItemsControl ItemsSource="{Binding Session.ProfilesList}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource Lumen.Button.Ghost}"
                              HorizontalContentAlignment="Left"
                              HorizontalAlignment="Stretch"
                              Command="{Binding DataContext.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal">
                          <Border Width="24" Height="24" CornerRadius="12"
                                  Background="{Binding AvatarColor, FallbackValue=#4C8DFF}"
                                  Margin="{StaticResource Lumen.Margin.R12}">
                            <TextBlock Text="{Binding Name, Converter={StaticResource Lumen.FirstLetter}}"
                                       FontSize="{StaticResource Lumen.FontSize.Micro}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                          </Border>
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator Background="{StaticResource Lumen.Brush.Stroke.Subtle}" Margin="{StaticResource Lumen.Pad.8}" />
                <Button Style="{StaticResource Lumen.Button.Ghost}"
                        HorizontalContentAlignment="Left"
                        HorizontalAlignment="Stretch"
                        Command="{Binding AddProfileCommand}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{StaticResource Lumen.Icon.Add}"
                               FontFamily="{StaticResource Lumen.Font.Icons}"
                               FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R12}" />
                    <TextBlock Text="{x:Static res:Strings.Shell_AddProfile}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding RailItems}"
                      Margin="{StaticResource Lumen.Margin.T16}"
                      Focusable="False">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Style="{StaticResource Lumen.RailItem}"
                      Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding Key}"
                      AutomationProperties.Name="{Binding Label}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </DockPanel>
    </Border>

    <!-- ======================= Content ======================= -->
    <!-- Fluent "layer" pane: pages sit on a faintly raised surface with a rounded top-left
         corner where it meets the rail and title bar, so the Mica shell reads as chrome and
         the content reads as the canvas. Full-bleed during onboarding (no rail). -->
    <Border Grid.Column="1">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsShellReady}" Value="True">
              <Setter Property="Background" Value="{StaticResource Lumen.Brush.Layer}" />
              <Setter Property="BorderBrush" Value="{StaticResource Lumen.Brush.Layer.Stroke}" />
              <Setter Property="BorderThickness" Value="1,1,0,0" />
              <Setter Property="CornerRadius" Value="8,0,0,0" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <ctl:TransitioningContentControl Content="{Binding Navigation.CurrentViewModel}"
                                       IsTabStop="False"
                                       Focusable="False" />
    </Border>

    <!-- ======================= Full player layer ======================= -->
    <Border Grid.Column="0"
            Grid.ColumnSpan="2"
            Background="{StaticResource Lumen.Brush.VideoBackground}"
            Visibility="{Binding Playback.IsFullPlayerActive, Converter={StaticResource Lumen.BoolToVisibility}}">
      <Grid>
        <!-- Fallback loading state. The native video HWND covers all WPF drawing in this area,
             so this only shows in the gaps the in-video overlay cannot cover: before LibVLC
             cold init finishes, and for the beat while the surface swap rebuilds the HWND.
             Those gaps are exactly when the click would otherwise show a dead black pane. -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding Playback.State, Converter={StaticResource Lumen.PlaybackStateVisibility}, ConverterParameter=Opening|Buffering}">
          <ContentControl Style="{StaticResource Lumen.Spinner}" HorizontalAlignment="Center" />
          <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                     Text="{Binding Playback.NowPlayingTitle}"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="520"
                     HorizontalAlignment="Center"
                     Margin="{StaticResource Lumen.Margin.T16}" />
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{x:Static res:Strings.Player_Opening}"
                     HorizontalAlignment="Center"
                     Margin="{StaticResource Lumen.Margin.T8}" />
        </StackPanel>
        <ctl:VideoSurface Kind="FullPlayer" />
      </Grid>
    </Border>

    <!-- The mini player is now a separate always-on-top window (Controls/MiniPlayerWindow.cs),
         shown/hidden from MainWindow.xaml.cs when Playback.IsMiniPlayerActive changes. -->


    <!-- ======================= Toasts ======================= -->
    <ItemsControl Grid.Column="0"
                  Grid.ColumnSpan="2"
                  ItemsSource="{Binding ToastItems}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="{StaticResource Lumen.Pad.24}"
                  IsHitTestVisible="False"
                  Focusable="False">
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type svc:ToastItem}">
          <ContentControl Content="{Binding Message}"
                          Margin="{StaticResource Lumen.Margin.T8}"
                          RenderTransformOrigin="0.5,1">
            <ContentControl.RenderTransform>
              <TranslateTransform Y="12" />
            </ContentControl.RenderTransform>
            <ContentControl.Style>
              <Style TargetType="ContentControl" BasedOn="{StaticResource Lumen.Toast}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Severity}" Value="Success">
                    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Success}" />
                    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Check}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Severity}" Value="Error">
                    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Error}" />
                    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Warning}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ContentControl.Style>
            <ContentControl.Triggers>
              <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="{theming:Dur Fast}" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="12" To="0"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </ContentControl.Triggers>
          </ContentControl>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</Window>
