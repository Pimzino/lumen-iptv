<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctl="clr-namespace:Lumen.App.Controls"
                    xmlns:theming="clr-namespace:Lumen.App.Theming">

  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/Themes/Lumen.Colors.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Metrics.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Typography.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Icons.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- ======================= Focus ======================= -->

  <!-- 2px accent ring, 2px outside the control bounds. Applied to every interactive style. -->
  <Style x:Key="Lumen.FocusVisual">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Rectangle Margin="-4"
                     RadiusX="10"
                     RadiusY="10"
                     Stroke="{StaticResource Lumen.Brush.Accent}"
                     StrokeThickness="2"
                     SnapsToDevicePixels="True" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Buttons ======================= -->

  <Style x:Key="Lumen.Button.Base" TargetType="{x:Type ButtonBase}">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="{StaticResource Lumen.Pad.Control}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ButtonBase}">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{StaticResource Lumen.Radius.Control}">
            <Grid>
              <Border x:Name="HoverOverlay"
                      Background="{StaticResource Lumen.Brush.Overlay.Hover}"
                      CornerRadius="{StaticResource Lumen.Radius.Control}"
                      Opacity="0" />
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True"
                                Focusable="False" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="HoverOverlay" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Pressed}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Lumen.Button.Primary" TargetType="Button" BasedOn="{StaticResource Lumen.Button.Base}">
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.OnAccent}" />
    <Style.Triggers>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Background" Value="{StaticResource Lumen.Brush.Accent.Pressed}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Lumen.Button.Secondary" TargetType="Button" BasedOn="{StaticResource Lumen.Button.Base}">
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Control.Rest}" />
    <Style.Triggers>
      <Trigger Property="IsPressed" Value="True">
        <Setter Property="Background" Value="{StaticResource Lumen.Brush.Control.Active}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Lumen.Button.Ghost" TargetType="Button" BasedOn="{StaticResource Lumen.Button.Base}">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="Padding" Value="{StaticResource Lumen.Pad.ControlCompact}" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Square icon button; set Content to a Lumen.Icon.* glyph. Works on Button and ToggleButton. -->
  <Style x:Key="Lumen.Button.Icon" TargetType="{x:Type ButtonBase}" BasedOn="{StaticResource Lumen.Button.Base}">
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Icons}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Icon}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="Width" Value="{StaticResource Lumen.Size.IconButton}" />
    <Setter Property="Height" Value="{StaticResource Lumen.Size.IconButton}" />
    <Setter Property="Padding" Value="0" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Unstyled buttons default to Secondary so nothing ships with WinForms-gray chrome. -->
  <Style TargetType="Button" BasedOn="{StaticResource Lumen.Button.Secondary}" />

  <!-- ======================= Caption buttons (window chrome) ======================= -->

  <Style x:Key="Lumen.Button.Caption" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="Width" Value="{StaticResource Lumen.Size.CaptionButtonWidth}" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="Transparent">
            <TextBlock Text="{TemplateBinding Content}"
                       FontFamily="{StaticResource Lumen.Font.Icons}"
                       FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                       Foreground="{TemplateBinding Foreground}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Hover}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Pressed}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Lumen.Button.CaptionClose" TargetType="Button" BasedOn="{StaticResource Lumen.Button.Caption}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="Transparent">
            <TextBlock Text="{TemplateBinding Content}"
                       FontFamily="{StaticResource Lumen.Font.Icons}"
                       FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                       Foreground="{TemplateBinding Foreground}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.CloseHover}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.OnAccent}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.ClosePressed}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Text fields (floating label) ======================= -->

  <Style x:Key="Lumen.TextBox" TargetType="TextBox">
    <Setter Property="ctl:LumenUi.EnableFloatingLabel" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="CaretBrush" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="SelectionBrush" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Field.Bg}" />
    <Setter Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Subtle}" />
    <Setter Property="BorderThickness" Value="{StaticResource Lumen.Stroke.Border}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="MinHeight" Value="52" />
    <Setter Property="AllowDrop" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{StaticResource Lumen.Radius.Control}">
            <Grid Margin="{StaticResource Lumen.Pad.Field}">
              <TextBlock x:Name="FloatingLabel"
                         Text="{Binding Path=(ctl:LumenUi.Label), RelativeSource={RelativeSource TemplatedParent}}"
                         Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                         FontSize="{TemplateBinding FontSize}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         IsHitTestVisible="False"
                         RenderTransformOrigin="0,0.5">
                <TextBlock.RenderTransform>
                  <TransformGroup>
                    <ScaleTransform x:Name="LabelScale" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="LabelShift" Y="0" />
                  </TransformGroup>
                </TextBlock.RenderTransform>
              </TextBlock>
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="0,14,0,0"
                            VerticalAlignment="Center"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="ctl:LumenUi.IsFloating" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="LabelShift"
                                     Storyboard.TargetProperty="Y"
                                     To="-11"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="0.734"
                                     Duration="{theming:Dur Fast}" />
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="0.734"
                                     Duration="{theming:Dur Fast}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="LabelShift"
                                     Storyboard.TargetProperty="Y"
                                     To="0"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1"
                                     Duration="{theming:Dur Fast}" />
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1"
                                     Duration="{theming:Dur Fast}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Strong}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Lumen.Brush.Accent}" />
              <Setter TargetName="FloatingLabel" Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Lumen.PasswordBox" TargetType="PasswordBox">
    <Setter Property="ctl:LumenUi.EnableFloatingLabel" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="CaretBrush" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="SelectionBrush" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Field.Bg}" />
    <Setter Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Subtle}" />
    <Setter Property="BorderThickness" Value="{StaticResource Lumen.Stroke.Border}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="MinHeight" Value="52" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="PasswordBox">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{StaticResource Lumen.Radius.Control}">
            <Grid Margin="{StaticResource Lumen.Pad.Field}">
              <TextBlock x:Name="FloatingLabel"
                         Text="{Binding Path=(ctl:LumenUi.Label), RelativeSource={RelativeSource TemplatedParent}}"
                         Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                         FontSize="{TemplateBinding FontSize}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         IsHitTestVisible="False"
                         RenderTransformOrigin="0,0.5">
                <TextBlock.RenderTransform>
                  <TransformGroup>
                    <ScaleTransform x:Name="LabelScale" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="LabelShift" Y="0" />
                  </TransformGroup>
                </TextBlock.RenderTransform>
              </TextBlock>
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="0,14,0,0"
                            VerticalAlignment="Center"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="ctl:LumenUi.IsFloating" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="LabelShift"
                                     Storyboard.TargetProperty="Y"
                                     To="-11"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="0.734"
                                     Duration="{theming:Dur Fast}" />
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="0.734"
                                     Duration="{theming:Dur Fast}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="LabelShift"
                                     Storyboard.TargetProperty="Y"
                                     To="0"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1"
                                     Duration="{theming:Dur Fast}" />
                    <DoubleAnimation Storyboard.TargetName="LabelScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1"
                                     Duration="{theming:Dur Fast}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Strong}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Lumen.Brush.Accent}" />
              <Setter TargetName="FloatingLabel" Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Toggle switch ======================= -->

  <Style x:Key="Lumen.Toggle" TargetType="CheckBox">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Grid VerticalAlignment="Center">
              <Border x:Name="Track"
                      Width="40"
                      Height="22"
                      CornerRadius="11"
                      Background="{StaticResource Lumen.Brush.Control.Rest}"
                      BorderBrush="{StaticResource Lumen.Brush.Stroke.Strong}"
                      BorderThickness="{StaticResource Lumen.Stroke.Border}" />
              <Ellipse x:Name="Thumb"
                       Width="14"
                       Height="14"
                       Fill="{StaticResource Lumen.Brush.Text.Secondary}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0">
                <Ellipse.RenderTransform>
                  <TranslateTransform x:Name="ThumbShift" X="0" />
                </Ellipse.RenderTransform>
              </Ellipse>
            </Grid>
            <ContentPresenter x:Name="LabelHost"
                              Margin="{StaticResource Lumen.Margin.L12}"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True" />
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ThumbShift"
                                     Storyboard.TargetProperty="X"
                                     To="18"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ThumbShift"
                                     Storyboard.TargetProperty="X"
                                     To="0"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
              <Setter TargetName="Track" Property="Background" Value="{StaticResource Lumen.Brush.Accent}" />
              <Setter TargetName="Track" Property="BorderBrush" Value="Transparent" />
              <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Lumen.Brush.Text.OnAccent}" />
            </Trigger>
            <Trigger Property="Content" Value="{x:Null}">
              <Setter TargetName="LabelHost" Property="Margin" Value="0" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Slider (volume, subtitle size) ======================= -->

  <Style x:Key="Lumen.Slider.RepeatButton" TargetType="RepeatButton">
    <Setter Property="Focusable" Value="False" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border Background="{TemplateBinding Background}"
                  Height="4"
                  CornerRadius="2"
                  VerticalAlignment="Center" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Lumen.Slider" TargetType="Slider">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Height" Value="24" />
    <Setter Property="IsMoveToPointEnabled" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource Lumen.Slider.RepeatButton}"
                              Background="{StaticResource Lumen.Brush.Accent}"
                              Command="Slider.DecreaseLarge" />
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource Lumen.Slider.RepeatButton}"
                              Background="{StaticResource Lumen.Brush.Control.Rest}"
                              Command="Slider.IncreaseLarge" />
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <Thumb Width="12" Height="12" Focusable="False">
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Ellipse x:Name="ThumbShape" Fill="{StaticResource Lumen.Brush.Text.Primary}" />
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="ThumbShape" Property="Fill" Value="{StaticResource Lumen.Brush.Accent.Hover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                          <Setter TargetName="ThumbShape" Property="Fill" Value="{StaticResource Lumen.Brush.Accent}" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= ComboBox ======================= -->

  <Style x:Key="Lumen.ComboBoxItem" TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="Padding" Value="{StaticResource Lumen.Pad.Row}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Root"
                  CornerRadius="{StaticResource Lumen.Radius.Badge}"
                  Background="Transparent"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Pressed}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Accent.Subtle}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Lumen.ComboBox" TargetType="ComboBox">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Field.Bg}" />
    <Setter Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Subtle}" />
    <Setter Property="BorderThickness" Value="{StaticResource Lumen.Stroke.Border}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="MaxDropDownHeight" Value="320" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource Lumen.ComboBoxItem}" />
    <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton x:Name="ToggleButton"
                          Focusable="False"
                          ClickMode="Press"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
              <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                  <Border x:Name="FieldRoot"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{StaticResource Lumen.Radius.Control}">
                    <TextBlock x:Name="Chevron"
                               Text="{StaticResource Lumen.Icon.ChevronDown}"
                               FontFamily="{StaticResource Lumen.Font.Icons}"
                               FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                               Foreground="{StaticResource Lumen.Brush.Text.Secondary}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R12}"
                               RenderTransformOrigin="0.5,0.5">
                      <TextBlock.RenderTransform>
                        <RotateTransform x:Name="ChevronRotate" Angle="0" />
                      </TextBlock.RenderTransform>
                    </TextBlock>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="FieldRoot" Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Strong}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                      <Trigger.EnterActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChevronRotate"
                                             Storyboard.TargetProperty="Angle"
                                             To="180"
                                             Duration="{theming:Dur Fast}">
                              <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut" />
                              </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                          </Storyboard>
                        </BeginStoryboard>
                      </Trigger.EnterActions>
                      <Trigger.ExitActions>
                        <BeginStoryboard>
                          <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ChevronRotate"
                                             Storyboard.TargetProperty="Angle"
                                             To="0"
                                             Duration="{theming:Dur Fast}">
                              <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut" />
                              </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                          </Storyboard>
                        </BeginStoryboard>
                      </Trigger.ExitActions>
                      <Setter TargetName="FieldRoot" Property="BorderBrush" Value="{StaticResource Lumen.Brush.Accent}" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <ContentPresenter x:Name="SelectedContent"
                              Margin="12,0,36,0"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
            <Popup x:Name="PART_Popup"
                   Placement="Bottom"
                   VerticalOffset="4"
                   AllowsTransparency="True"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   PopupAnimation="None"
                   Focusable="False">
              <Border x:Name="DropDownBorder"
                      Background="{StaticResource Lumen.Brush.Bg.Overlay}"
                      BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                      BorderThickness="{StaticResource Lumen.Stroke.Border}"
                      CornerRadius="{StaticResource Lumen.Radius.Control}"
                      Padding="{StaticResource Lumen.Pad.4}"
                      MinWidth="{Binding ActualWidth, ElementName=ToggleButton}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                <ScrollViewer>
                  <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBox" BasedOn="{StaticResource Lumen.ComboBox}" />

</ResourceDictionary>
