<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctl="clr-namespace:Lumen.App.Controls"
                    xmlns:theming="clr-namespace:Lumen.App.Theming">

  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/Themes/Lumen.Colors.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Metrics.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Typography.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Icons.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Converters.xaml" />
    <ResourceDictionary Source="/Themes/Controls/Lumen.Controls.Core.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- Rail navigation item. DataContext is a RailItem (Key, Glyph, Label, IsActive). -->
  <Style x:Key="Lumen.RailItem" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Height" Value="44" />
    <Setter Property="Margin" Value="8,2" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="Transparent"
                  CornerRadius="{StaticResource Lumen.Radius.Control}">
            <Grid>
              <Border x:Name="ActivePill"
                      Width="3"
                      Height="20"
                      CornerRadius="1.5"
                      Background="{StaticResource Lumen.Brush.Accent}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Opacity="0" />
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="Glyph"
                           Text="{Binding Glyph}"
                           FontFamily="{StaticResource Lumen.Font.Icons}"
                           FontSize="{StaticResource Lumen.FontSize.IconLarge}"
                           Foreground="{TemplateBinding Foreground}"
                           Width="56"
                           TextAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="Label"
                           Text="{Binding Label}"
                           FontFamily="{StaticResource Lumen.Font.Text}"
                           FontSize="{StaticResource Lumen.FontSize.Body}"
                           FontWeight="SemiBold"
                           Foreground="{TemplateBinding Foreground}"
                           VerticalAlignment="Center"
                           Visibility="{Binding DataContext.IsRailExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource Lumen.BoolToVisibility}}" />
              </StackPanel>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Hover}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
            </Trigger>
            <DataTrigger Binding="{Binding IsActive}" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Accent.Subtle}" />
              <Setter TargetName="ActivePill" Property="Opacity" Value="1" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
              <Setter TargetName="Glyph" Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Rail action: a standing command shown as a rail row. Reuses Lumen.RailItem's icon column
       (56px glyph, centred) and its reveal-label-when-expanded behaviour, but for a fixed command
       rather than a nav destination — the glyph comes from ctl:LumenUi.Glyph, the label from
       Content. Used for the rail's bottom actions (e.g. Buy me a coffee) so they read as a labelled
       row when the rail is expanded instead of a lone icon, with the glyph lined up under the nav
       items above. -->
  <Style x:Key="Lumen.RailAction" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Height" Value="44" />
    <Setter Property="Margin" Value="8,2" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="Transparent"
                  CornerRadius="{StaticResource Lumen.Radius.Control}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock x:Name="Glyph"
                         Text="{Binding Path=(ctl:LumenUi.Glyph), RelativeSource={RelativeSource TemplatedParent}}"
                         FontFamily="{StaticResource Lumen.Font.Icons}"
                         FontSize="{StaticResource Lumen.FontSize.IconLarge}"
                         Foreground="{TemplateBinding Foreground}"
                         Width="56"
                         TextAlignment="Center"
                         VerticalAlignment="Center" />
              <TextBlock Text="{TemplateBinding Content}"
                         FontFamily="{StaticResource Lumen.Font.Text}"
                         FontSize="{StaticResource Lumen.FontSize.Body}"
                         FontWeight="SemiBold"
                         Foreground="{TemplateBinding Foreground}"
                         VerticalAlignment="Center"
                         Visibility="{Binding DataContext.IsRailExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource Lumen.BoolToVisibility}}" />
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Hover}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Rail-bottom profile chip. DataContext is the ShellViewModel. -->
  <Style x:Key="Lumen.ProfileChip" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Height" Value="56" />
    <Setter Property="Margin" Value="8,8" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="Transparent" CornerRadius="{StaticResource Lumen.Radius.Control}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Grid Width="56">
                <Border Width="32"
                        Height="32"
                        CornerRadius="16"
                        Background="{Binding Session.CurrentProfile.AvatarColor, FallbackValue=#4C8DFF}">
                  <TextBlock Text="{Binding Session.CurrentProfile.Name, Converter={StaticResource Lumen.FirstLetter}}"
                             FontFamily="{StaticResource Lumen.Font.Text}"
                             FontSize="{StaticResource Lumen.FontSize.Caption}"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Border>
              </Grid>
              <TextBlock Text="{Binding Session.CurrentProfile.Name}"
                         FontFamily="{StaticResource Lumen.Font.Text}"
                         FontSize="{StaticResource Lumen.FontSize.Caption}"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource Lumen.Brush.Text.Primary}"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsRailExpanded, Converter={StaticResource Lumen.BoolToVisibility}}" />
            </StackPanel>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Hover}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Segmented tab button used by onboarding (Xtream / M3U). -->
  <Style x:Key="Lumen.SegmentButton" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="{StaticResource Lumen.Pad.ControlCompact}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root" Background="Transparent" CornerRadius="{StaticResource Lumen.Radius.Badge}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
            </Trigger>
            <Trigger Property="Tag" Value="active">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Control.Rest}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Onboarding progress dot; Tag "active" lights it. -->
  <Style x:Key="Lumen.StepDot" TargetType="Border">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Margin" Value="4,0" />
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Control.Rest}" />
    <Style.Triggers>
      <Trigger Property="Tag" Value="active">
        <Setter Property="Background" Value="{StaticResource Lumen.Brush.Accent}" />
      </Trigger>
    </Style.Triggers>
  </Style>

</ResourceDictionary>
