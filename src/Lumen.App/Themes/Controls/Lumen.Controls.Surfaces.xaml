<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctl="clr-namespace:Lumen.App.Controls"
                    xmlns:theming="clr-namespace:Lumen.App.Theming">

  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/Themes/Lumen.Colors.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Metrics.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Typography.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Icons.xaml" />
    <ResourceDictionary Source="/Themes/Controls/Lumen.Controls.Core.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- ======================= Cards ======================= -->

  <Style x:Key="Lumen.Card" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Bg.Raised}" />
    <Setter Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Subtle}" />
    <Setter Property="BorderThickness" Value="{StaticResource Lumen.Stroke.Border}" />
    <Setter Property="CornerRadius" Value="{StaticResource Lumen.Radius.Card}" />
    <Setter Property="Padding" Value="{StaticResource Lumen.Pad.16}" />
  </Style>

  <!--
    Clickable poster/channel card. Scales to 1.04 on hover with the ambient glow fading in.
    Views supply the poster via an inner Border with an ImageBrush background.
  -->
  <Style x:Key="Lumen.PosterCard" TargetType="Button">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Bg.Raised}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border x:Name="Glow"
                    Background="{StaticResource Lumen.Brush.Glow.Accent}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}"
                    Margin="-10"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <Border x:Name="Surface"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                    BorderThickness="{StaticResource Lumen.Stroke.Border}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1.04"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1.04"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Glow"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1"
                                     Duration="{theming:Dur Fast}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Glow"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0"
                                     Duration="{theming:Dur Fast}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Glow" Property="Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!--
    Hover play affordance for card media: an accent disc that fades in while the pointer
    (or keyboard focus) is on the owning card button. Place inside a card's media Grid;
    it is decorative — the card button itself is the click target.
  -->
  <Style x:Key="Lumen.PlayChip" TargetType="ContentControl">
    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Play}" />
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Border Background="{StaticResource Lumen.Brush.Accent}" CornerRadius="999">
            <TextBlock Text="{Binding Path=(ctl:LumenUi.Glyph), RelativeSource={RelativeSource TemplatedParent}}"
                       FontFamily="{StaticResource Lumen.Font.Icons}"
                       FontSize="{StaticResource Lumen.FontSize.Icon}"
                       Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
        <DataTrigger.EnterActions>
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="{theming:Dur Fast}" />
            </Storyboard>
          </BeginStoryboard>
        </DataTrigger.EnterActions>
        <DataTrigger.ExitActions>
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="{theming:Dur Fast}" />
            </Storyboard>
          </BeginStoryboard>
        </DataTrigger.ExitActions>
      </DataTrigger>
      <DataTrigger Binding="{Binding IsKeyboardFocused, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
        <DataTrigger.EnterActions>
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="{theming:Dur Fast}" />
            </Storyboard>
          </BeginStoryboard>
        </DataTrigger.EnterActions>
        <DataTrigger.ExitActions>
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="{theming:Dur Fast}" />
            </Storyboard>
          </BeginStoryboard>
        </DataTrigger.ExitActions>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- ======================= Badges ======================= -->

  <Style x:Key="Lumen.Badge" TargetType="ContentControl">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Lumen.Brush.Stroke.Strong}" />
    <Setter Property="BorderThickness" Value="{StaticResource Lumen.Stroke.Border}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Micro}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{StaticResource Lumen.Radius.Badge}"
                  Padding="{StaticResource Lumen.Pad.Badge}">
            <ContentPresenter VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- LIVE badge: the one place Bold is allowed. The red is reserved for liveness, never errors. -->
  <Style x:Key="Lumen.Badge.Live" TargetType="ContentControl" BasedOn="{StaticResource Lumen.Badge}">
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Live}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.OnAccent}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <!-- Quality badge (HD / 4K): quiet outline. -->
  <Style x:Key="Lumen.Badge.Quality" TargetType="ContentControl" BasedOn="{StaticResource Lumen.Badge}" />

  <Style x:Key="Lumen.Badge.New" TargetType="ContentControl" BasedOn="{StaticResource Lumen.Badge}">
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Accent.Subtle}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
  </Style>

  <!-- ======================= Progress ======================= -->

  <!-- 2px bar used for EPG "now" progress and resume positions. -->
  <Style x:Key="Lumen.ProgressBar" TargetType="ProgressBar">
    <Setter Property="Height" Value="{StaticResource Lumen.Size.ProgressBar}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Control.Rest}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Grid x:Name="PART_Track" SnapsToDevicePixels="True">
            <Border Background="{TemplateBinding Background}" CornerRadius="1" />
            <Border x:Name="PART_Indicator"
                    Background="{TemplateBinding Foreground}"
                    CornerRadius="1"
                    HorizontalAlignment="Left" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ProgressBar" BasedOn="{StaticResource Lumen.ProgressBar}" />

  <!-- ======================= Skeleton ======================= -->

  <Style TargetType="ctl:SkeletonBlock">
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="MinHeight" Value="{StaticResource Lumen.Space.3}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ctl:SkeletonBlock">
          <Border x:Name="ShimmerHost" CornerRadius="{TemplateBinding CornerRadius}">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <LinearGradientBrush.RelativeTransform>
                  <!-- Unnamed Freezable; animated via a property path off the named Border below. -->
                  <TranslateTransform X="-1" />
                </LinearGradientBrush.RelativeTransform>
                <GradientStop Offset="0" Color="{StaticResource Lumen.Color.Skeleton.Base}" />
                <GradientStop Offset="0.35" Color="{StaticResource Lumen.Color.Skeleton.Base}" />
                <GradientStop Offset="0.5" Color="{StaticResource Lumen.Color.Skeleton.Glint}" />
                <GradientStop Offset="0.65" Color="{StaticResource Lumen.Color.Skeleton.Base}" />
                <GradientStop Offset="1" Color="{StaticResource Lumen.Color.Skeleton.Base}" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <ControlTemplate.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
              <BeginStoryboard>
                <Storyboard RepeatBehavior="{theming:Loop}">
                  <DoubleAnimation Storyboard.TargetName="ShimmerHost"
                                   Storyboard.TargetProperty="(Border.Background).(Brush.RelativeTransform).(TranslateTransform.X)"
                                   From="-1"
                                   To="2"
                                   Duration="{theming:Dur Shimmer}" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Spinner ======================= -->

  <!-- Rotating quarter-arc used for buffering and long operations. -->
  <Style x:Key="Lumen.Spinner" TargetType="ContentControl">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Grid>
            <Ellipse Stroke="{StaticResource Lumen.Brush.Control.Rest}"
                     StrokeThickness="3"
                     Margin="2" />
            <Path x:Name="Arc"
                  Data="M 16,2 A 14,14 0 0 1 30,16"
                  Stroke="{StaticResource Lumen.Brush.Accent}"
                  StrokeThickness="3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  RenderTransformOrigin="0.5,0.5"
                  Stretch="None">
              <Path.RenderTransform>
                <!-- Inline (unshared) so the Angle sub-property stays animatable. -->
                <RotateTransform Angle="0" />
              </Path.RenderTransform>
              <!-- The rotation lives in the Path's own EventTrigger with NO Storyboard.TargetName,
                   so it targets this element directly. Storyboard.TargetName resolution against a
                   ControlTemplate namescope is unreliable for nested children (throws "name cannot
                   be found in the name scope of ControlTemplate") — this sidesteps the lookup. -->
              <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="{theming:Loop}">
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                       From="0"
                                       To="360"
                                       Duration="0:0:0.9" />
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Path.Triggers>
            </Path>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Toasts ======================= -->

  <Style x:Key="Lumen.Toast" TargetType="ContentControl">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Info}" />
    <Setter Property="MinWidth" Value="280" />
    <Setter Property="MaxWidth" Value="420" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <Grid>
            <!-- Shadow lives on its own layer so the text above stays crisp. -->
            <Border Background="{StaticResource Lumen.Brush.Bg.OverlaySolid}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}">
              <Border.Effect>
                <DropShadowEffect Color="{StaticResource Lumen.Color.Shadow}"
                                  Direction="270"
                                  ShadowDepth="8"
                                  BlurRadius="24"
                                  Opacity="0.35" />
              </Border.Effect>
            </Border>
            <Border Background="{StaticResource Lumen.Brush.Glass}"
                    BorderBrush="{StaticResource Lumen.Brush.Stroke.Glass}"
                    BorderThickness="{StaticResource Lumen.Stroke.Border}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}"
                    Padding="{StaticResource Lumen.Pad.Toast}">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left"
                         Text="{Binding Path=(ctl:LumenUi.Glyph), RelativeSource={RelativeSource TemplatedParent}}"
                         FontFamily="{StaticResource Lumen.Font.Icons}"
                         FontSize="{StaticResource Lumen.FontSize.Icon}"
                         Foreground="{TemplateBinding Foreground}"
                         VerticalAlignment="Center"
                         Margin="{StaticResource Lumen.Margin.R12}" />
              <ContentPresenter VerticalAlignment="Center"
                                TextElement.Foreground="{StaticResource Lumen.Brush.Text.Primary}"
                                TextElement.FontFamily="{StaticResource Lumen.Font.Text}"
                                TextElement.FontSize="{StaticResource Lumen.FontSize.Body}" />
            </DockPanel>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Lumen.Toast.Success" TargetType="ContentControl" BasedOn="{StaticResource Lumen.Toast}">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Success}" />
    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Check}" />
  </Style>

  <Style x:Key="Lumen.Toast.Error" TargetType="ContentControl" BasedOn="{StaticResource Lumen.Toast}">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Error}" />
    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Warning}" />
  </Style>

  <!-- ======================= Empty state ======================= -->

  <!-- Designed empty state: a soft glyph disc over secondary text. Set the icon via
       ctl:LumenUi.Glyph and the message as Content. -->
  <Style x:Key="Lumen.EmptyState" TargetType="ContentControl">
    <Setter Property="ctl:LumenUi.Glyph" Value="{StaticResource Lumen.Icon.Info}" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContentControl">
          <StackPanel HorizontalAlignment="Center">
            <Border Width="64"
                    Height="64"
                    CornerRadius="32"
                    Background="{StaticResource Lumen.Brush.Control.Rest}"
                    BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                    BorderThickness="{StaticResource Lumen.Stroke.Border}"
                    HorizontalAlignment="Center"
                    Margin="{StaticResource Lumen.Margin.B16}">
              <TextBlock Text="{Binding Path=(ctl:LumenUi.Glyph), RelativeSource={RelativeSource TemplatedParent}}"
                         FontFamily="{StaticResource Lumen.Font.Icons}"
                         FontSize="28"
                         Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <ContentPresenter HorizontalAlignment="Center"
                              TextElement.Foreground="{StaticResource Lumen.Brush.Text.Secondary}"
                              TextElement.FontFamily="{StaticResource Lumen.Font.Text}"
                              TextElement.FontSize="{StaticResource Lumen.FontSize.Body}" />
          </StackPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Window chrome ======================= -->

  <Style x:Key="Lumen.Window" TargetType="Window">
    <Setter Property="Background" Value="{StaticResource Lumen.Brush.Bg.Base}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="ctl:LumenChrome.EnableWindowCommands" Value="True" />
    <!-- Dark DWM frame + Win11 rounded corners + Mica backdrop (graceful no-ops downlevel). -->
    <Setter Property="ctl:WindowFx.Effects" Value="Mica" />
    <Setter Property="WindowChrome.WindowChrome">
      <Setter.Value>
        <!-- CaptionHeight matches Lumen.Size.TitleBar. GlassFrameThickness is a deliberate
             1px bottom sliver: it must be NON-ZERO so the DWM owns every non-client repaint
             (a zero frame hands NC repaints to the classic theme, which used to draw
             Windows-95-style caption buttons over the custom title bar during the fullscreen
             transitions) — but it must NOT cover the caption region, because the DWM paints
             its own ghost min/max/close glyphs into any frame sheet extended up there, and
             they shimmer through the translucent Mica tint. The backdrop itself does not
             need the extension: DWMWA_SYSTEMBACKDROP_TYPE is whole-window base material. -->
        <WindowChrome CaptionHeight="48"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Window">
          <Border x:Name="WindowRoot" Background="{TemplateBinding Background}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Grid x:Name="TitleBar" Grid.Row="0" Height="{StaticResource Lumen.Size.TitleBar}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <Image Source="pack://application:,,,/Assets/lumen.ico"
                         Width="16"
                         Height="16"
                         RenderOptions.BitmapScalingMode="HighQuality"
                         VerticalAlignment="Center"
                         Margin="16,0,0,0" />
                  <TextBlock Text="{TemplateBinding Title}"
                             FontFamily="{StaticResource Lumen.Font.Display}"
                             FontSize="{StaticResource Lumen.FontSize.Caption}"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Lumen.Brush.Text.Secondary}"
                             VerticalAlignment="Center"
                             Margin="{StaticResource Lumen.Margin.L8}" />
                </StackPanel>

                <ContentPresenter Grid.Column="1"
                                  Content="{Binding Path=(ctl:LumenChrome.TitleBarContent), RelativeSource={RelativeSource TemplatedParent}}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  WindowChrome.IsHitTestVisibleInChrome="True" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                  <Button x:Name="MinButton"
                          Style="{StaticResource Lumen.Button.Caption}"
                          Content="{StaticResource Lumen.Icon.WindowMinimize}"
                          Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                          AutomationProperties.Name="Minimize" />
                  <Button x:Name="MaxButton"
                          Style="{StaticResource Lumen.Button.Caption}"
                          Content="{StaticResource Lumen.Icon.WindowMaximize}"
                          Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                          ctl:WindowFx.IsSnapTarget="True"
                          AutomationProperties.Name="Maximize" />
                  <Button x:Name="CloseButton"
                          Style="{StaticResource Lumen.Button.CaptionClose}"
                          Content="{StaticResource Lumen.Icon.WindowClose}"
                          Command="{x:Static SystemCommands.CloseWindowCommand}"
                          AutomationProperties.Name="Close" />
                </StackPanel>
              </Grid>

              <AdornerDecorator Grid.Row="1">
                <ContentPresenter />
              </AdornerDecorator>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <!-- With a live Mica backdrop the root swaps to a translucent tint so the desktop's
                 luminance breathes through the chrome, Windows-11 style. -->
            <Trigger Property="ctl:WindowFx.IsBackdropActive" Value="True">
              <Setter TargetName="WindowRoot" Property="Background" Value="{StaticResource Lumen.Brush.Window.Tint}" />
            </Trigger>
            <!-- Compensate for the OS overhang when a borderless window maximizes. -->
            <Trigger Property="WindowState" Value="Maximized">
              <Setter TargetName="WindowRoot" Property="Margin" Value="7" />
              <Setter TargetName="MaxButton" Property="Content" Value="{StaticResource Lumen.Icon.WindowRestore}" />
              <Setter TargetName="MaxButton" Property="AutomationProperties.Name" Value="Restore" />
            </Trigger>
            <!-- Edge-to-edge player: no chrome at all. -->
            <Trigger Property="ctl:LumenChrome.IsImmersive" Value="True">
              <Setter TargetName="TitleBar" Property="Visibility" Value="Collapsed" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ======================= Dialog window ======================= -->

  <!-- Applied by LumenDialogWindow; the only surface in the app that casts a shadow. -->
  <Style x:Key="Lumen.DialogWindow" TargetType="{x:Type ctl:LumenDialogWindow}">
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{StaticResource Lumen.Font.Text}" />
    <Setter Property="FontSize" Value="{StaticResource Lumen.FontSize.Body}" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="ctl:LumenChrome.EnableWindowCommands" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ctl:LumenDialogWindow}">
          <Grid Margin="48">
            <Border Background="{StaticResource Lumen.Brush.Bg.Raised}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}">
              <Border.Effect>
                <DropShadowEffect Color="{StaticResource Lumen.Color.Shadow}"
                                  Direction="270"
                                  ShadowDepth="16"
                                  BlurRadius="48"
                                  Opacity="0.5" />
              </Border.Effect>
            </Border>
            <Border Background="{StaticResource Lumen.Brush.Glass}"
                    BorderBrush="{StaticResource Lumen.Brush.Stroke.Glass}"
                    BorderThickness="{StaticResource Lumen.Stroke.Border}"
                    CornerRadius="{StaticResource Lumen.Radius.Card}">
              <AdornerDecorator>
                <ContentPresenter />
              </AdornerDecorator>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
