<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctl="clr-namespace:Lumen.App.Controls"
                    xmlns:theming="clr-namespace:Lumen.App.Theming">

  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="/Themes/Lumen.Colors.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Metrics.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Typography.xaml" />
    <ResourceDictionary Source="/Themes/Lumen.Icons.xaml" />
    <ResourceDictionary Source="/Themes/Controls/Lumen.Controls.Core.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!--
    Settings sidebar tab. A restyled TabItem so the native TabControl still owns selection and
    keyboard navigation; only the chrome changes. Mirrors Lumen.RailItem: a 3px accent pill, an
    icon glyph (carried on Tag), and a label (Header). Rest = secondary; hover = primary wash;
    selected = accent-subtle fill, accent glyph, pill faded in.
  -->
  <Style x:Key="Lumen.SettingsTabItem" TargetType="TabItem">
    <Setter Property="FocusVisualStyle" Value="{StaticResource Lumen.FocusVisual}" />
    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Secondary}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Margin" Value="8,2" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="Root"
                  Height="44"
                  Background="Transparent"
                  CornerRadius="{StaticResource Lumen.Radius.Control}">
            <Grid>
              <Border x:Name="ActivePill"
                      Width="3"
                      Height="20"
                      CornerRadius="1.5"
                      Background="{StaticResource Lumen.Brush.Accent}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Opacity="0" />
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,12,0">
                <TextBlock x:Name="Glyph"
                           Text="{TemplateBinding Tag}"
                           FontFamily="{StaticResource Lumen.Font.Icons}"
                           FontSize="{StaticResource Lumen.FontSize.IconLarge}"
                           Foreground="{TemplateBinding Foreground}"
                           Width="28"
                           VerticalAlignment="Center" />
                <ContentPresenter x:Name="LabelHost"
                                  ContentSource="Header"
                                  VerticalAlignment="Center"
                                  TextElement.FontFamily="{StaticResource Lumen.Font.Text}"
                                  TextElement.FontSize="{StaticResource Lumen.FontSize.Body}"
                                  TextElement.FontWeight="SemiBold"
                                  TextElement.Foreground="{TemplateBinding Foreground}" />
              </StackPanel>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Overlay.Hover}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource Lumen.Brush.Accent.Subtle}" />
              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Text.Primary}" />
              <Setter TargetName="Glyph" Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ActivePill"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ActivePill"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0"
                                     Duration="{theming:Dur Fast}">
                      <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!--
    Settings shell: a fixed left sidebar (the items host) and an animated content pane. The
    section swap plays the app's standard fade+rise via TransitioningContentControl, which
    collapses to an instant cut when the OS disables animations.
  -->
  <Style x:Key="Lumen.SettingsTabs" TargetType="TabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="ItemContainerStyle" Value="{StaticResource Lumen.SettingsTabItem}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="232"
                    BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                    BorderThickness="0,0,1,0">
              <StackPanel x:Name="HeaderPanel"
                          IsItemsHost="True"
                          KeyboardNavigation.DirectionalNavigation="Cycle"
                          Margin="0,4,0,0" />
            </Border>

            <ctl:TransitioningContentControl Grid.Column="1"
                                             Margin="24,0,0,0"
                                             Content="{TemplateBinding SelectedContent}"
                                             ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
