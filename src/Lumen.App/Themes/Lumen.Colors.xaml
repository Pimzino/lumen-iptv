<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    mc:Ignorable="po">

  <!--
    Lumen color tokens. Semantic names only; a light theme would swap this dictionary.
    Views must never use literal colors — if a color is missing here, add a token.
  -->

  <!-- Backgrounds -->
  <Color x:Key="Lumen.Color.Bg.Base">#0B0D10</Color>
  <Color x:Key="Lumen.Color.Bg.Raised">#14171C</Color>
  <Color x:Key="Lumen.Color.Bg.Overlay">#E61C2027</Color>
  <Color x:Key="Lumen.Color.Bg.OverlaySolid">#1C2027</Color>

  <!-- Strokes -->
  <Color x:Key="Lumen.Color.Stroke.Subtle">#14FFFFFF</Color>
  <Color x:Key="Lumen.Color.Stroke.Strong">#26FFFFFF</Color>

  <!-- Text -->
  <Color x:Key="Lumen.Color.Text.Primary">#F2F4F7</Color>
  <Color x:Key="Lumen.Color.Text.Secondary">#9AA3AF</Color>
  <Color x:Key="Lumen.Color.Text.Tertiary">#5C6470</Color>
  <Color x:Key="Lumen.Color.Text.Disabled">#525A66</Color>
  <Color x:Key="Lumen.Color.Text.OnAccent">#FFFFFF</Color>

  <!-- Accent -->
  <Color x:Key="Lumen.Color.Accent">#4C8DFF</Color>
  <Color x:Key="Lumen.Color.Accent.Hover">#5E99FF</Color>
  <Color x:Key="Lumen.Color.Accent.Pressed">#3B74D9</Color>
  <Color x:Key="Lumen.Color.Accent.Subtle">#1F4C8DFF</Color>

  <!-- Status -->
  <Color x:Key="Lumen.Color.Live">#FF4D5E</Color>
  <Color x:Key="Lumen.Color.Live.Subtle">#1FFF4D5E</Color>
  <Color x:Key="Lumen.Color.Error">#F97066</Color>
  <Color x:Key="Lumen.Color.Error.Subtle">#1FF97066</Color>
  <Color x:Key="Lumen.Color.Success">#47CD89</Color>
  <Color x:Key="Lumen.Color.Success.Subtle">#1F47CD89</Color>

  <!-- Interaction overlays (white washes on dark surfaces) -->
  <Color x:Key="Lumen.Color.Overlay.Hover">#0AFFFFFF</Color>
  <Color x:Key="Lumen.Color.Overlay.Pressed">#14FFFFFF</Color>

  <!-- Modal scrim behind flyouts/dialogs -->
  <Color x:Key="Lumen.Color.Scrim">#99000000</Color>

  <!-- Near-invisible fill (alpha 1/255) for full-bleed mouse-catch layers over the video. The
       player overlay lives in LibVLCSharp's layered airspace window, where fully transparent
       (alpha 0) pixels are click-through at the OS level and stop delivering mouse events; a
       1/255 alpha keeps the surface hit-testable without being visible. -->
  <Color x:Key="Lumen.Color.Overlay.HitTarget">#01000000</Color>

  <!-- Control fills -->
  <Color x:Key="Lumen.Color.Control.Rest">#14FFFFFF</Color>
  <Color x:Key="Lumen.Color.Control.Active">#1FFFFFFF</Color>
  <Color x:Key="Lumen.Color.Field.Bg">#0AFFFFFF</Color>

  <!-- Chrome -->
  <Color x:Key="Lumen.Color.CloseHover">#C42B1C</Color>
  <Color x:Key="Lumen.Color.ClosePressed">#B12A1B</Color>
  <Color x:Key="Lumen.Color.ScrollThumb">#33FFFFFF</Color>
  <Color x:Key="Lumen.Color.ScrollThumbHover">#4DFFFFFF</Color>
  <Color x:Key="Lumen.Color.Skeleton.Base">#161A20</Color>
  <Color x:Key="Lumen.Color.Skeleton.Glint">#212731</Color>
  <Color x:Key="Lumen.Color.Shadow">#000000</Color>

  <!-- ======================= Brushes ======================= -->

  <SolidColorBrush x:Key="Lumen.Brush.Bg.Base" Color="{StaticResource Lumen.Color.Bg.Base}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Bg.Raised" Color="{StaticResource Lumen.Color.Bg.Raised}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Bg.Overlay" Color="{StaticResource Lumen.Color.Bg.Overlay}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Bg.OverlaySolid" Color="{StaticResource Lumen.Color.Bg.OverlaySolid}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.Stroke.Subtle" Color="{StaticResource Lumen.Color.Stroke.Subtle}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Stroke.Strong" Color="{StaticResource Lumen.Color.Stroke.Strong}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.Text.Primary" Color="{StaticResource Lumen.Color.Text.Primary}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Text.Secondary" Color="{StaticResource Lumen.Color.Text.Secondary}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Text.Tertiary" Color="{StaticResource Lumen.Color.Text.Tertiary}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Text.Disabled" Color="{StaticResource Lumen.Color.Text.Disabled}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Text.OnAccent" Color="{StaticResource Lumen.Color.Text.OnAccent}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.Accent" Color="{StaticResource Lumen.Color.Accent}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Accent.Hover" Color="{StaticResource Lumen.Color.Accent.Hover}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Accent.Pressed" Color="{StaticResource Lumen.Color.Accent.Pressed}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Accent.Subtle" Color="{StaticResource Lumen.Color.Accent.Subtle}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.Live" Color="{StaticResource Lumen.Color.Live}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Live.Subtle" Color="{StaticResource Lumen.Color.Live.Subtle}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Error" Color="{StaticResource Lumen.Color.Error}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Error.Subtle" Color="{StaticResource Lumen.Color.Error.Subtle}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Success" Color="{StaticResource Lumen.Color.Success}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Success.Subtle" Color="{StaticResource Lumen.Color.Success.Subtle}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.Overlay.Hover" Color="{StaticResource Lumen.Color.Overlay.Hover}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Overlay.Pressed" Color="{StaticResource Lumen.Color.Overlay.Pressed}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Scrim" Color="{StaticResource Lumen.Color.Scrim}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Overlay.HitTarget" Color="{StaticResource Lumen.Color.Overlay.HitTarget}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.Control.Rest" Color="{StaticResource Lumen.Color.Control.Rest}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Control.Active" Color="{StaticResource Lumen.Color.Control.Active}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.Field.Bg" Color="{StaticResource Lumen.Color.Field.Bg}" po:Freeze="True" />

  <SolidColorBrush x:Key="Lumen.Brush.CloseHover" Color="{StaticResource Lumen.Color.CloseHover}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.ClosePressed" Color="{StaticResource Lumen.Color.ClosePressed}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.ScrollThumb" Color="{StaticResource Lumen.Color.ScrollThumb}" po:Freeze="True" />
  <SolidColorBrush x:Key="Lumen.Brush.ScrollThumbHover" Color="{StaticResource Lumen.Color.ScrollThumbHover}" po:Freeze="True" />

  <!-- Solid black behind video surfaces (letterbox bars). -->
  <SolidColorBrush x:Key="Lumen.Brush.VideoBackground" Color="{StaticResource Lumen.Color.Shadow}" po:Freeze="True" />

  <!-- Gradient scrims for imagery and the player overlay -->
  <LinearGradientBrush x:Key="Lumen.Brush.Scrim.Top" StartPoint="0,0" EndPoint="0,1" po:Freeze="True">
    <GradientStop Offset="0" Color="#CC0B0D10" />
    <GradientStop Offset="1" Color="#000B0D10" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="Lumen.Brush.Scrim.Bottom" StartPoint="0,0" EndPoint="0,1" po:Freeze="True">
    <GradientStop Offset="0" Color="#000B0D10" />
    <GradientStop Offset="1" Color="#CC0B0D10" />
  </LinearGradientBrush>

  <!-- Placeholder ambient glow (accent-tinted); Phase 8 swaps in sampled dominant colors. -->
  <RadialGradientBrush x:Key="Lumen.Brush.Glow.Accent" po:Freeze="True">
    <GradientStop Offset="0" Color="#334C8DFF" />
    <GradientStop Offset="1" Color="#004C8DFF" />
  </RadialGradientBrush>

</ResourceDictionary>
