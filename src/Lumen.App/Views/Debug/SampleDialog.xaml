<ctl:LumenDialogWindow x:Class="Lumen.App.Views.Debug.SampleDialog"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:ctl="clr-namespace:Lumen.App.Controls"
                       Title="Sample dialog">
  <StackPanel Width="360" Margin="{StaticResource Lumen.Pad.24}">
    <TextBlock Style="{StaticResource Lumen.Text.Heading}"
               Text="Remove profile?"
               Margin="{StaticResource Lumen.Margin.B8}" />
    <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
               TextWrapping="Wrap"
               Text="This removes “Living room” and its favorites from this device. Your provider account is not affected."
               Margin="{StaticResource Lumen.Margin.B24}" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Style="{StaticResource Lumen.Button.Ghost}"
              Content="Cancel"
              IsCancel="True"
              Margin="{StaticResource Lumen.Margin.R8}" />
      <Button Style="{StaticResource Lumen.Button.Primary}"
              Content="Remove"
              IsDefault="True"
              Click="OnConfirmClick" />
    </StackPanel>
  </StackPanel>
</ctl:LumenDialogWindow>
