<ctl:LumenDialogWindow x:Class="Lumen.App.Views.Dialogs.CrashDialog"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:ctl="clr-namespace:Lumen.App.Controls"
                       xmlns:res="clr-namespace:Lumen.App.Resources"
                       Title="Lumen">
  <StackPanel Width="440" Margin="{StaticResource Lumen.Pad.24}">
    <TextBlock Style="{StaticResource Lumen.Text.Icon}"
               Text="{StaticResource Lumen.Icon.Warning}"
               FontSize="{StaticResource Lumen.FontSize.Title}"
               Foreground="{StaticResource Lumen.Brush.Error}"
               Margin="{StaticResource Lumen.Margin.B12}" />
    <TextBlock Style="{StaticResource Lumen.Text.Heading}"
               Text="{x:Static res:Strings.Crash_Title}"
               Margin="{StaticResource Lumen.Margin.B8}" />
    <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
               Text="{x:Static res:Strings.Crash_Body}"
               TextWrapping="Wrap"
               Margin="{StaticResource Lumen.Margin.B16}" />
    <Border Background="{StaticResource Lumen.Brush.Field.Bg}"
            BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
            BorderThickness="{StaticResource Lumen.Stroke.Border}"
            CornerRadius="{StaticResource Lumen.Radius.Control}"
            Padding="{StaticResource Lumen.Pad.12}"
            Margin="{StaticResource Lumen.Margin.B16}">
      <TextBlock x:Name="MessageText"
                 Style="{StaticResource Lumen.Text.Caption}"
                 Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                 TextWrapping="Wrap"
                 MaxHeight="120" />
    </Border>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Style="{StaticResource Lumen.Button.Ghost}"
              Content="{x:Static res:Strings.Crash_OpenLogs}"
              Click="OnOpenLogsClick"
              Margin="{StaticResource Lumen.Margin.R8}" />
      <Button Style="{StaticResource Lumen.Button.Primary}"
              Content="{x:Static res:Strings.Common_Close}"
              IsDefault="True"
              IsCancel="True"
              Click="OnCloseClick" />
    </StackPanel>
  </StackPanel>
</ctl:LumenDialogWindow>
