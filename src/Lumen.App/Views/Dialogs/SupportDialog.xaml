<ctl:LumenDialogWindow x:Class="Lumen.App.Views.Dialogs.SupportDialog"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:ctl="clr-namespace:Lumen.App.Controls"
                       xmlns:res="clr-namespace:Lumen.App.Resources">
  <StackPanel Width="400" Margin="{StaticResource Lumen.Pad.24}">
    <TextBlock FontFamily="{StaticResource Lumen.Font.Icons}"
               Text="{StaticResource Lumen.Icon.BuyCoffee}"
               FontSize="40"
               Foreground="{StaticResource Lumen.Brush.Accent}"
               Margin="{StaticResource Lumen.Margin.B12}" />
    <TextBlock Style="{StaticResource Lumen.Text.Heading}"
               Text="{x:Static res:Strings.Support_PromptTitle}"
               Margin="{StaticResource Lumen.Margin.B8}" />
    <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
               Text="{x:Static res:Strings.Support_PromptBody}"
               TextWrapping="Wrap"
               Margin="{StaticResource Lumen.Margin.B24}" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Style="{StaticResource Lumen.Button.Ghost}"
              Content="{x:Static res:Strings.Support_MaybeLater}"
              IsCancel="True"
              Margin="{StaticResource Lumen.Margin.R8}" />
      <Button Style="{StaticResource Lumen.Button.Primary}"
              Content="{x:Static res:Strings.Support_BuyCoffee}"
              IsDefault="True"
              Click="OnBuyClick" />
    </StackPanel>
  </StackPanel>
</ctl:LumenDialogWindow>
