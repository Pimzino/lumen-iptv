<UserControl x:Class="Lumen.App.Views.FavoritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources">
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="{StaticResource Lumen.Pad.Page}">
        <TextBlock Style="{StaticResource Lumen.Text.Display}"
                   Text="{x:Static res:Strings.Nav_Favorites}"
                   Margin="{StaticResource Lumen.Margin.B24}" />

        <!-- Loading skeleton -->
        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
          <ctl:SkeletonBlock Width="180" Height="20" HorizontalAlignment="Left"
                             Margin="{StaticResource Lumen.Margin.B16}" />
          <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B32}">
            <ctl:SkeletonBlock Width="240" Height="64" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="240" Height="64" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="240" Height="64" CornerRadius="12" />
          </StackPanel>
          <ctl:SkeletonBlock Width="180" Height="20" HorizontalAlignment="Left"
                             Margin="{StaticResource Lumen.Margin.B16}" />
          <StackPanel Orientation="Horizontal">
            <ctl:SkeletonBlock Width="150" Height="225" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="225" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="225" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="225" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="225" CornerRadius="12" />
          </StackPanel>
        </StackPanel>

        <!-- Empty -->
        <ContentControl Style="{StaticResource Lumen.EmptyState}"
                        ctl:LumenUi.Glyph="{StaticResource Lumen.Icon.Favorites}"
                        HorizontalAlignment="Center"
                        Margin="0,64,0,0"
                        Visibility="{Binding IsEmpty, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{x:Static res:Strings.Favorites_Empty}"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     MaxWidth="420" />
        </ContentControl>

        <!-- Channels -->
        <StackPanel Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding Channels.Count, Converter={StaticResource Lumen.CountToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Nav_LiveTv}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ItemsControl ItemsSource="{Binding Channels}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource Lumen.PosterCard}"
                        Width="240"
                        Margin="{StaticResource Lumen.Margin.R16}"
                        Command="{Binding DataContext.ActivateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        AutomationProperties.Name="{Binding Name}">
                  <Border Style="{StaticResource Lumen.Card}">
                    <StackPanel Orientation="Horizontal">
                      <Grid Width="40" Height="40">
                        <Border CornerRadius="{StaticResource Lumen.Radius.Control}"
                                Background="{StaticResource Lumen.Brush.Accent.Subtle}">
                          <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                                     Text="{Binding Monogram}"
                                     Foreground="{StaticResource Lumen.Brush.Accent}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Border>
                        <Image ctl:ImageLoader.Url="{Binding ImageUrl}"
                               ctl:ImageLoader.DecodeWidth="80"
                               Stretch="Uniform"
                               Margin="2" />
                      </Grid>
                      <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                                 Text="{Binding Name}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"
                                 Margin="{StaticResource Lumen.Margin.L12}" />
                    </StackPanel>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Movies -->
        <StackPanel Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding Movies.Count, Converter={StaticResource Lumen.CountToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Nav_Movies}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ItemsControl ItemsSource="{Binding Movies}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource Lumen.PosterCard}"
                        Width="150"
                        Margin="{StaticResource Lumen.Margin.R16}"
                        Command="{Binding DataContext.ActivateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        AutomationProperties.Name="{Binding Name}">
                  <StackPanel>
                    <Grid Height="225">
                      <Border CornerRadius="{StaticResource Lumen.Radius.Card}"
                              Background="{StaticResource Lumen.Brush.Accent.Subtle}">
                        <TextBlock Style="{StaticResource Lumen.Text.Display}"
                                   Text="{Binding Monogram}"
                                   Foreground="{StaticResource Lumen.Brush.Accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                      <Border CornerRadius="{StaticResource Lumen.Radius.Card}" ClipToBounds="True">
                        <Image ctl:ImageLoader.Url="{Binding ImageUrl}"
                               ctl:ImageLoader.DecodeWidth="300"
                               Stretch="UniformToFill" />
                      </Border>
                    </Grid>
                    <TextBlock Style="{StaticResource Lumen.Text.CaptionStrong}"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               Margin="4,8,4,8" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Series -->
        <StackPanel Visibility="{Binding Series.Count, Converter={StaticResource Lumen.CountToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Nav_Series}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ItemsControl ItemsSource="{Binding Series}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource Lumen.PosterCard}"
                        Width="150"
                        Margin="{StaticResource Lumen.Margin.R16}"
                        Command="{Binding DataContext.ActivateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        AutomationProperties.Name="{Binding Name}">
                  <StackPanel>
                    <Grid Height="225">
                      <Border CornerRadius="{StaticResource Lumen.Radius.Card}"
                              Background="{StaticResource Lumen.Brush.Accent.Subtle}">
                        <TextBlock Style="{StaticResource Lumen.Text.Display}"
                                   Text="{Binding Monogram}"
                                   Foreground="{StaticResource Lumen.Brush.Accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                      <Border CornerRadius="{StaticResource Lumen.Radius.Card}" ClipToBounds="True">
                        <Image ctl:ImageLoader.Url="{Binding ImageUrl}"
                               ctl:ImageLoader.DecodeWidth="300"
                               Stretch="UniformToFill" />
                      </Border>
                    </Grid>
                    <TextBlock Style="{StaticResource Lumen.Text.CaptionStrong}"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               Margin="4,8,4,8" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
