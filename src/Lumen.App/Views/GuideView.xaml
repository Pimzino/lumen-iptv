<UserControl x:Class="Lumen.App.Views.GuideView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:epg="clr-namespace:Lumen.App.Controls.Epg"
             xmlns:res="clr-namespace:Lumen.App.Resources"
             xmlns:theming="clr-namespace:Lumen.App.Theming">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- ============ Toolbar ============ -->
    <Grid Margin="24,16,24,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Style="{StaticResource Lumen.Text.Title}"
                 Text="{x:Static res:Strings.Nav_Guide}"
                 VerticalAlignment="Center"
                 Margin="{StaticResource Lumen.Margin.R24}" />

      <ComboBox Grid.Column="1"
                Width="180"
                VerticalAlignment="Center"
                ItemsSource="{Binding Days}"
                SelectedItem="{Binding SelectedDay}"
                Margin="{StaticResource Lumen.Margin.R12}"
                AutomationProperties.Name="Day">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Label}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>

      <ComboBox Grid.Column="2"
                Width="220"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                ctl:LumenUi.ShowPopupFilter="True"
                ctl:LumenUi.PopupFilterText="{Binding CategoryFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                AutomationProperties.Name="Category filter">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>

      <Button Grid.Column="3"
              Style="{StaticResource Lumen.Button.Secondary}"
              Command="{Binding JumpToNowCommand}"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{StaticResource Lumen.Icon.JumpToNow}"
                     FontFamily="{StaticResource Lumen.Font.Icons}"
                     FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                     VerticalAlignment="Center"
                     Margin="{StaticResource Lumen.Margin.R8}" />
          <TextBlock Text="{x:Static res:Strings.Guide_JumpToNow}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- ============ Timeline ============ -->
    <Grid Grid.Row="1">
      <!-- loading -->
      <StackPanel Margin="{StaticResource Lumen.Pad.24}"
                  Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
        <ctl:SkeletonBlock Height="40" Margin="{StaticResource Lumen.Margin.B8}" />
        <ctl:SkeletonBlock Height="56" Margin="{StaticResource Lumen.Margin.B8}" />
        <ctl:SkeletonBlock Height="56" Margin="{StaticResource Lumen.Margin.B8}" />
        <ctl:SkeletonBlock Height="56" Margin="{StaticResource Lumen.Margin.B8}" />
        <ctl:SkeletonBlock Height="56" />
      </StackPanel>

      <!-- empty -->
      <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                 Text="{x:Static res:Strings.Guide_NoData}"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 MaxWidth="320"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Visibility="{Binding HasData, Converter={StaticResource Lumen.InverseBoolToVisibility}}" />

      <!-- guide grid -->
      <ScrollViewer x:Name="GuideScroller"
                    CanContentScroll="True"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsLoading, Converter={StaticResource Lumen.InverseBoolToVisibility}}">
        <epg:EpgGuidePanel x:Name="Guide"
                           Rows="{Binding Rows}"
                           TimelineStart="{Binding TimelineStart}"
                           TimelineEnd="{Binding TimelineEnd}"
                           Now="{Binding Now}"
                           PixelsPerMinute="6"
                           AutomationProperties.Name="Programme guide" />
      </ScrollViewer>

      <!-- programme detail flyout -->
      <Grid Visibility="{Binding IsFlyoutOpen, Converter={StaticResource Lumen.BoolToVisibility}}">
        <Border Background="{StaticResource Lumen.Brush.Scrim}" />
        <Border HorizontalAlignment="Right"
                Width="420"
                Background="{StaticResource Lumen.Brush.Bg.OverlaySolid}"
                BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                BorderThickness="1,0,0,0"
                RenderTransformOrigin="1,0.5">
          <Border.RenderTransform>
            <TranslateTransform X="0" />
          </Border.RenderTransform>
          <Border.Triggers>
            <!-- No Storyboard.TargetName: targets this Border's own RenderTransform. -->
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                   From="420" To="0"
                                   Duration="{theming:Dur Slow}">
                    <DoubleAnimation.EasingFunction>
                      <CubicEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                  </DoubleAnimation>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </Border.Triggers>
          <DockPanel Margin="{StaticResource Lumen.Pad.24}"
                     DataContext="{Binding SelectedProgramme}">
            <Button DockPanel.Dock="Top"
                    Style="{StaticResource Lumen.Button.Icon}"
                    Content="{StaticResource Lumen.Icon.Close}"
                    HorizontalAlignment="Right"
                    Command="{Binding DataContext.CloseFlyoutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    AutomationProperties.Name="{x:Static res:Strings.Common_Close}" />
            <StackPanel DockPanel.Dock="Bottom" Margin="{StaticResource Lumen.Margin.T16}">
              <Button Style="{StaticResource Lumen.Button.Primary}"
                      HorizontalAlignment="Stretch"
                      Command="{Binding DataContext.WatchChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Content="{x:Static res:Strings.Guide_WatchChannel}"
                      Margin="{StaticResource Lumen.Margin.B8}" />
              <Button Style="{StaticResource Lumen.Button.Secondary}"
                      HorizontalAlignment="Stretch"
                      Click="OnAddReminderClick"
                      Content="{x:Static res:Strings.Guide_AddReminder}" />
            </StackPanel>
            <StackPanel>
              <TextBlock Style="{StaticResource Lumen.Text.CaptionStrong}"
                         Foreground="{StaticResource Lumen.Brush.Accent}"
                         Text="{Binding ChannelName}"
                         Margin="{StaticResource Lumen.Margin.B8}" />
              <TextBlock Style="{StaticResource Lumen.Text.Title}"
                         Text="{Binding Title}"
                         TextWrapping="Wrap"
                         Margin="{StaticResource Lumen.Margin.B8}" />
              <TextBlock Style="{StaticResource Lumen.Text.TabularCaption}"
                         Text="{Binding TimeRange}"
                         Margin="{StaticResource Lumen.Margin.B16}" />
              <ContentControl Style="{StaticResource Lumen.Badge.Quality}"
                              Content="{Binding Category}"
                              HorizontalAlignment="Left"
                              Margin="{StaticResource Lumen.Margin.B16}"
                              Visibility="{Binding Category, Converter={StaticResource Lumen.NullToCollapsed}}" />
              <TextBlock Style="{StaticResource Lumen.Text.Body}"
                         Foreground="{StaticResource Lumen.Brush.Text.Secondary}"
                         Text="{Binding Description}"
                         TextWrapping="Wrap"
                         Visibility="{Binding Description, Converter={StaticResource Lumen.NullToCollapsed}}" />
            </StackPanel>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
