<UserControl x:Class="Lumen.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources">
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="{StaticResource Lumen.Pad.Page}">

        <TextBlock Style="{StaticResource Lumen.Text.Display}"
                   Text="{Binding ProfileName}"
                   Margin="{StaticResource Lumen.Margin.B24}" />

        <!-- Loading skeletons -->
        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
          <ctl:SkeletonBlock Width="220" Height="20" HorizontalAlignment="Left" Margin="{StaticResource Lumen.Margin.B16}" />
          <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B32}">
            <ctl:SkeletonBlock Width="150" Height="260" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="260" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="260" CornerRadius="12" Margin="{StaticResource Lumen.Margin.R16}" />
            <ctl:SkeletonBlock Width="150" Height="260" CornerRadius="12" />
          </StackPanel>
        </StackPanel>

        <!-- Empty state -->
        <Border Style="{StaticResource Lumen.Card}"
                HorizontalAlignment="Left"
                MaxWidth="480"
                Visibility="{Binding IsEmpty, Converter={StaticResource Lumen.BoolToVisibility}}">
          <StackPanel>
            <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                       Text="{x:Static res:Strings.Home_ContinueWatching}"
                       Margin="{StaticResource Lumen.Margin.B8}" />
            <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                       Text="{x:Static res:Strings.Home_EmptyBody}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- ============ Continue watching ============ -->
        <StackPanel Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding HasContinueWatching, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Home_ContinueWatching}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ContinueWatching}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource Lumen.PosterCard}"
                          Width="280"
                          Margin="0,0,16,0"
                          Command="{Binding DataContext.PlayContinueCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}"
                          AutomationProperties.Name="{Binding Title}">
                    <StackPanel>
                      <Grid Height="158">
                        <Border CornerRadius="{StaticResource Lumen.Radius.Card}"
                                Background="{StaticResource Lumen.Brush.Accent.Subtle}">
                          <TextBlock Style="{StaticResource Lumen.Text.Display}"
                                     Text="{Binding Monogram}"
                                     Foreground="{StaticResource Lumen.Brush.Accent}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Border>
                        <Border CornerRadius="{StaticResource Lumen.Radius.Card}" ClipToBounds="True">
                          <Image ctl:ImageLoader.Url="{Binding ImageUrl}"
                                 ctl:ImageLoader.DecodeWidth="560"
                                 Stretch="UniformToFill"
                                 RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                                     Maximum="100"
                                     VerticalAlignment="Bottom"
                                     Margin="8,0,8,8" />
                      </Grid>
                      <TextBlock Style="{StaticResource Lumen.Text.CaptionStrong}"
                                 Text="{Binding Title}"
                                 TextTrimming="CharacterEllipsis"
                                 Margin="4,8,4,0" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>

        <!-- ============ Favorite channels ============ -->
        <StackPanel Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding HasFavoriteChannels, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Home_FavoriteChannels}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FavoriteChannels}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource Lumen.PosterCard}"
                          Width="260"
                          Margin="0,0,16,0"
                          Command="{Binding DataContext.PlayChannelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}"
                          AutomationProperties.Name="{Binding Name}">
                    <Border Style="{StaticResource Lumen.Card}">
                      <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B8}">
                          <Grid Width="40" Height="40">
                            <Border CornerRadius="{StaticResource Lumen.Radius.Control}"
                                    Background="{StaticResource Lumen.Brush.Accent.Subtle}">
                              <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                                         Text="{Binding Monogram}"
                                         Foreground="{StaticResource Lumen.Brush.Accent}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                            </Border>
                            <Image ctl:ImageLoader.Url="{Binding LogoUrl}"
                                   ctl:ImageLoader.DecodeWidth="80"
                                   Stretch="Uniform"
                                   Margin="2" />
                          </Grid>
                          <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                                     Text="{Binding Name}"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center"
                                     Margin="{StaticResource Lumen.Margin.L12}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                                   Text="{Binding NowTitle}"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding NowTitle, Converter={StaticResource Lumen.NullToCollapsed}}" />
                        <ProgressBar Value="{Binding NowProgress, Mode=OneWay}"
                                     Maximum="100"
                                     Margin="{StaticResource Lumen.Margin.T8}"
                                     Visibility="{Binding NowTitle, Converter={StaticResource Lumen.NullToCollapsed}}" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>

        <!-- ============ Recently added movies ============ -->
        <StackPanel Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding HasRecentMovies, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Home_RecentlyAddedMovies}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RecentMovies}"
                          ItemTemplate="{StaticResource Lumen.Template.PosterTile}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>

        <!-- ============ New series ============ -->
        <StackPanel Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding HasRecentSeries, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Home_RecentlyAddedSeries}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RecentSeries}"
                          ItemTemplate="{StaticResource Lumen.Template.PosterTile}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
