<UserControl x:Class="Lumen.App.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources">
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel MaxWidth="460"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="{StaticResource Lumen.Pad.Page}">

        <!-- Progress dots (steps 1–3) -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="{StaticResource Lumen.Margin.B32}"
                    Visibility="{Binding IsWelcomeStep, Converter={StaticResource Lumen.InverseBoolToVisibility}}">
          <Border Style="{StaticResource Lumen.StepDot}"
                  Tag="{Binding Step, Converter={StaticResource Lumen.ActiveWhenEqual}, ConverterParameter=1}" />
          <Border Style="{StaticResource Lumen.StepDot}"
                  Tag="{Binding Step, Converter={StaticResource Lumen.ActiveWhenEqual}, ConverterParameter=2}" />
          <Border Style="{StaticResource Lumen.StepDot}"
                  Tag="{Binding Step, Converter={StaticResource Lumen.ActiveWhenEqual}, ConverterParameter=3}" />
        </StackPanel>

        <!-- ============ Step 0: welcome ============ -->
        <StackPanel Visibility="{Binding IsWelcomeStep, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Display}"
                     Text="{x:Static res:Strings.Onboarding_WelcomeTitle}"
                     TextAlignment="Center"
                     Margin="{StaticResource Lumen.Margin.B12}" />
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{x:Static res:Strings.Onboarding_WelcomeBody}"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B32}" />
          <Button Style="{StaticResource Lumen.Button.Primary}"
                  Content="{x:Static res:Strings.Onboarding_GetStarted}"
                  Command="{Binding BeginCommand}"
                  HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ============ Step 1: add service ============ -->
        <StackPanel Visibility="{Binding IsServiceStep, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Onboarding_AddServiceTitle}"
                     Margin="{StaticResource Lumen.Margin.B8}" />
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{x:Static res:Strings.Onboarding_AddServiceBody}"
                     TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B24}" />

          <!-- Segmented tabs -->
          <Border Background="{StaticResource Lumen.Brush.Field.Bg}"
                  CornerRadius="{StaticResource Lumen.Radius.Control}"
                  Padding="{StaticResource Lumen.Pad.4}"
                  HorizontalAlignment="Left"
                  Margin="{StaticResource Lumen.Margin.B24}">
            <StackPanel Orientation="Horizontal">
              <Button Style="{StaticResource Lumen.SegmentButton}"
                      Content="{x:Static res:Strings.Onboarding_TabXtream}"
                      Command="{Binding SelectTabCommand}"
                      CommandParameter="xtream"
                      Tag="{Binding IsXtreamTab, Converter={StaticResource Lumen.ActiveWhenEqual}, ConverterParameter=True}" />
              <Button Style="{StaticResource Lumen.SegmentButton}"
                      Content="{x:Static res:Strings.Onboarding_TabM3u}"
                      Command="{Binding SelectTabCommand}"
                      CommandParameter="m3u"
                      Tag="{Binding IsM3uTab, Converter={StaticResource Lumen.ActiveWhenEqual}, ConverterParameter=True}" />
            </StackPanel>
          </Border>

          <!-- Xtream form -->
          <StackPanel Visibility="{Binding IsXtreamTab, Converter={StaticResource Lumen.BoolToVisibility}}">
            <TextBox Style="{StaticResource Lumen.TextBox}"
                     ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_ProfileName}"
                     Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
            <TextBox Style="{StaticResource Lumen.TextBox}"
                     ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_Server}"
                     Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
            <TextBox Style="{StaticResource Lumen.TextBox}"
                     ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_Username}"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
            <PasswordBox Style="{StaticResource Lumen.PasswordBox}"
                         ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_Password}"
                         ctl:LumenUi.BindPassword="True"
                         ctl:LumenUi.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="{StaticResource Lumen.Margin.B16}" />
          </StackPanel>

          <!-- M3U form -->
          <StackPanel Visibility="{Binding IsM3uTab, Converter={StaticResource Lumen.BoolToVisibility}}">
            <TextBox Style="{StaticResource Lumen.TextBox}"
                     ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_ProfileName}"
                     Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
            <Grid Margin="{StaticResource Lumen.Margin.B16}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox Style="{StaticResource Lumen.TextBox}"
                       ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_PlaylistSource}"
                       Text="{Binding PlaylistSource, UpdateSourceTrigger=PropertyChanged}" />
              <Button Grid.Column="1"
                      Style="{StaticResource Lumen.Button.Ghost}"
                      Content="{x:Static res:Strings.Common_Browse}"
                      Command="{Binding BrowsePlaylistCommand}"
                      VerticalAlignment="Center"
                      Margin="{StaticResource Lumen.Margin.L8}" />
            </Grid>
          </StackPanel>

          <!-- Test result -->
          <TextBlock TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B16}"
                     Visibility="{Binding TestMessage, Converter={StaticResource Lumen.NullToCollapsed}}"
                     Text="{Binding TestMessage}">
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Lumen.Text.Caption}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding TestFailed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Error}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding TestSucceeded}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Success}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <StackPanel Orientation="Horizontal">
            <Button Style="{StaticResource Lumen.Button.Secondary}"
                    Content="{x:Static res:Strings.Onboarding_TestConnection}"
                    Command="{Binding TestConnectionCommand}"
                    Margin="{StaticResource Lumen.Margin.R12}" />
            <Button Style="{StaticResource Lumen.Button.Primary}"
                    Content="{x:Static res:Strings.Common_Continue}"
                    Command="{Binding ContinueToEpgCommand}" />
          </StackPanel>
        </StackPanel>

        <!-- ============ Step 2: EPG ============ -->
        <StackPanel Visibility="{Binding IsEpgStep, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Onboarding_EpgTitle}"
                     Margin="{StaticResource Lumen.Margin.B8}" />
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B24}"
                     Visibility="{Binding IsXtreamTab, Converter={StaticResource Lumen.BoolToVisibility}}"
                     Text="{x:Static res:Strings.Onboarding_EpgBodyXtream}" />
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B24}"
                     Visibility="{Binding IsM3uTab, Converter={StaticResource Lumen.BoolToVisibility}}"
                     Text="{x:Static res:Strings.Onboarding_EpgBodyM3u}" />

          <Grid Margin="{StaticResource Lumen.Margin.B16}"
                Visibility="{Binding IsM3uTab, Converter={StaticResource Lumen.BoolToVisibility}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Style="{StaticResource Lumen.TextBox}"
                     ctl:LumenUi.Label="{x:Static res:Strings.Onboarding_EpgSource}"
                     Text="{Binding EpgSource, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1"
                    Style="{StaticResource Lumen.Button.Ghost}"
                    Content="{x:Static res:Strings.Common_Browse}"
                    Command="{Binding BrowseEpgCommand}"
                    VerticalAlignment="Center"
                    Margin="{StaticResource Lumen.Margin.L8}" />
          </Grid>

          <CheckBox Style="{StaticResource Lumen.Toggle}"
                    Content="{x:Static res:Strings.Onboarding_ImportEpgNow}"
                    IsChecked="{Binding ImportEpgNow}"
                    Margin="{StaticResource Lumen.Margin.B24}" />

          <StackPanel Orientation="Horizontal">
            <Button Style="{StaticResource Lumen.Button.Ghost}"
                    Content="{x:Static res:Strings.Common_Back}"
                    Command="{Binding GoBackCommand}"
                    Margin="{StaticResource Lumen.Margin.R12}" />
            <Button Style="{StaticResource Lumen.Button.Primary}"
                    Content="{x:Static res:Strings.Onboarding_Finish}"
                    Command="{Binding FinishCommand}" />
          </StackPanel>
        </StackPanel>

        <!-- ============ Step 3: working ============ -->
        <StackPanel Visibility="{Binding IsWorkingStep, Converter={StaticResource Lumen.BoolToVisibility}}">
          <TextBlock Style="{StaticResource Lumen.Text.Title}"
                     Text="{x:Static res:Strings.Onboarding_WorkingTitle}"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <ctl:SkeletonBlock Height="4"
                             CornerRadius="2"
                             Margin="{StaticResource Lumen.Margin.B16}"
                             Visibility="{Binding WorkFailed, Converter={StaticResource Lumen.InverseBoolToVisibility}}" />
          <TextBlock TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B16}"
                     Text="{Binding WorkStatus}">
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Lumen.Text.Body}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding WorkFailed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Error}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <ItemsControl ItemsSource="{Binding WorkLog}" Margin="{StaticResource Lumen.Margin.B16}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B4}">
                  <TextBlock Text="{StaticResource Lumen.Icon.Check}"
                             FontFamily="{StaticResource Lumen.Font.Icons}"
                             FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                             Foreground="{StaticResource Lumen.Brush.Success}"
                             VerticalAlignment="Center"
                             Margin="{StaticResource Lumen.Margin.R8}" />
                  <TextBlock Style="{StaticResource Lumen.Text.Caption}" Text="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding WorkFailed, Converter={StaticResource Lumen.BoolToVisibility}}">
            <Button Style="{StaticResource Lumen.Button.Ghost}"
                    Content="{x:Static res:Strings.Common_Back}"
                    Command="{Binding RetryAfterFailureCommand}"
                    Margin="{StaticResource Lumen.Margin.R12}" />
            <Button Style="{StaticResource Lumen.Button.Primary}"
                    Content="{x:Static res:Strings.Common_Retry}"
                    Command="{Binding FinishCommand}" />
          </StackPanel>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
