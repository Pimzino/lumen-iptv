<UserControl x:Class="Lumen.App.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources">
  <Grid Margin="{StaticResource Lumen.Pad.Page}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Search field -->
    <Border Grid.Row="0"
            Background="{StaticResource Lumen.Brush.Field.Bg}"
            BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
            BorderThickness="{StaticResource Lumen.Stroke.Border}"
            CornerRadius="{StaticResource Lumen.Radius.Control}"
            MaxWidth="640"
            HorizontalAlignment="Left"
            Margin="{StaticResource Lumen.Margin.B24}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{StaticResource Lumen.Icon.Search}"
                   FontFamily="{StaticResource Lumen.Font.Icons}"
                   FontSize="{StaticResource Lumen.FontSize.Icon}"
                   Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0" />
        <TextBox x:Name="SearchBox"
                 Grid.Column="1"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource Lumen.Brush.Text.Primary}"
                 CaretBrush="{StaticResource Lumen.Brush.Accent}"
                 FontSize="{StaticResource Lumen.FontSize.Heading}"
                 VerticalContentAlignment="Center"
                 Padding="12,14"
                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.Name="{x:Static res:Strings.Search_Placeholder}" />
      </Grid>
    </Border>

    <!-- Prompt / empty / results -->
    <TextBlock Grid.Row="1"
               Style="{StaticResource Lumen.Text.BodySecondary}"
               Text="{x:Static res:Strings.Search_Prompt}"
               VerticalAlignment="Top"
               Visibility="{Binding HasQuery, Converter={StaticResource Lumen.InverseBoolToVisibility}}" />

    <TextBlock Grid.Row="1"
               VerticalAlignment="Top"
               Text="{Binding Query, StringFormat={x:Static res:Strings.Search_NoResultsFormat}}">
      <TextBlock.Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource Lumen.Text.BodySecondary}">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers>
            <MultiDataTrigger>
              <MultiDataTrigger.Conditions>
                <Condition Binding="{Binding HasQuery}" Value="True" />
                <Condition Binding="{Binding HasResults}" Value="False" />
                <Condition Binding="{Binding IsSearching}" Value="False" />
              </MultiDataTrigger.Conditions>
              <Setter Property="Visibility" Value="Visible" />
            </MultiDataTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding HasResults, Converter={StaticResource Lumen.BoolToVisibility}}">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="{StaticResource Lumen.Margin.B24}">
              <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                         Text="{Binding Header}"
                         Margin="{StaticResource Lumen.Margin.B12}" />
              <ItemsControl ItemsSource="{Binding Hits}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Style="{StaticResource Lumen.Button.Ghost}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="{StaticResource Lumen.Pad.12}"
                            Margin="{StaticResource Lumen.Margin.B4}"
                            Command="{Binding DataContext.ActivateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Lumen.Text.Body}"
                                   Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                                   Text="{Binding Subtitle}"
                                   Margin="{StaticResource Lumen.Margin.L12}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding Subtitle, Converter={StaticResource Lumen.NullToCollapsed}}" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
