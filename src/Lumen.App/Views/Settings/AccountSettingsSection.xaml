<UserControl x:Class="Lumen.App.Views.Settings.AccountSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="760" HorizontalAlignment="Left" Margin="0,0,16,24">

      <!-- ============ Profiles ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_Profiles}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B24}">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="{StaticResource Lumen.Margin.B8}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border Width="36" Height="36" CornerRadius="18"
                          Background="{Binding AvatarColor}"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding Monogram}"
                               FontFamily="{StaticResource Lumen.Font.Text}"
                               FontSize="{StaticResource Lumen.FontSize.Body}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center"
                              Margin="{StaticResource Lumen.Margin.L12}">
                    <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}" Text="{Binding Name}" />
                    <TextBlock Style="{StaticResource Lumen.Text.Micro}" Text="{Binding KindLabel}" />
                  </StackPanel>
                  <ContentControl Grid.Column="2"
                                  Style="{StaticResource Lumen.Badge.New}"
                                  Content="{x:Static res:Strings.Settings_ProfileActive}"
                                  Margin="{StaticResource Lumen.Margin.R12}"
                                  Visibility="{Binding IsActive, Converter={StaticResource Lumen.BoolToVisibility}}" />
                  <Button Grid.Column="3"
                          Style="{StaticResource Lumen.Button.Ghost}"
                          Content="{x:Static res:Strings.Settings_ProfileSwitch}"
                          Command="{Binding DataContext.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          Margin="{StaticResource Lumen.Margin.R8}"
                          Visibility="{Binding IsActive, Converter={StaticResource Lumen.InverseBoolToVisibility}}" />
                  <Button Grid.Column="4"
                          Style="{StaticResource Lumen.Button.Ghost}"
                          Content="{x:Static res:Strings.Common_Edit}"
                          Command="{Binding DataContext.EditProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          Margin="{StaticResource Lumen.Margin.R8}" />
                  <Button Grid.Column="5"
                          Style="{StaticResource Lumen.Button.DangerGhost}"
                          Content="{x:Static res:Strings.Common_Remove}"
                          Command="{Binding DataContext.RemoveProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Style="{StaticResource Lumen.Button.Secondary}"
                  Content="{x:Static res:Strings.Shell_AddProfile}"
                  Command="{Binding AddProfileCommand}"
                  HorizontalAlignment="Left"
                  Margin="{StaticResource Lumen.Margin.T8}" />
        </StackPanel>
      </Border>

      <!-- ============ Account (Xtream only) ============ -->
      <StackPanel Visibility="{Binding IsCurrentProfileXtream, Converter={StaticResource Lumen.BoolToVisibility}}">
        <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                   Text="{x:Static res:Strings.Settings_Account}"
                   Margin="{StaticResource Lumen.Margin.B12}" />
        <Border Style="{StaticResource Lumen.Card}">
          <StackPanel>

            <!-- Loading -->
            <ctl:SkeletonBlock Height="150" CornerRadius="8"
                               Visibility="{Binding IsAccountLoading, Converter={StaticResource Lumen.BoolToVisibility}}" />

            <!-- Fetch failed -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding AccountLoadFailed, Converter={StaticResource Lumen.BoolToVisibility}}">
              <TextBlock Style="{StaticResource Lumen.Text.Body}"
                         Foreground="{StaticResource Lumen.Brush.Error}"
                         Text="{x:Static res:Strings.Settings_AccountLoadFailed}"
                         VerticalAlignment="Center"
                         Margin="{StaticResource Lumen.Margin.R12}" />
              <Button Style="{StaticResource Lumen.Button.Secondary}"
                      Content="{x:Static res:Strings.Common_Refresh}"
                      Command="{Binding RefreshAccountCommand}" />
            </StackPanel>

            <!-- Details -->
            <StackPanel Visibility="{Binding AccountReady, Converter={StaticResource Lumen.BoolToVisibility}}">

              <!-- Headline stat tiles: the three details users check most. -->
              <Grid Margin="{StaticResource Lumen.Margin.B16}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Status -->
                <Border Grid.Column="0"
                        Background="{StaticResource Lumen.Brush.Control.Rest}"
                        BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                        BorderThickness="{StaticResource Lumen.Stroke.Border}"
                        CornerRadius="{StaticResource Lumen.Radius.Control}"
                        Padding="{StaticResource Lumen.Pad.16}">
                  <StackPanel>
                    <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                               Text="{x:Static res:Strings.Settings_AccountStatus}"
                               Margin="{StaticResource Lumen.Margin.B8}" />
                    <StackPanel Orientation="Horizontal">
                      <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R8}">
                        <Ellipse.Style>
                          <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource Lumen.Brush.Success}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding AccountStatusIsHealthy}" Value="False">
                                <Setter Property="Fill" Value="{StaticResource Lumen.Brush.Error}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Ellipse.Style>
                      </Ellipse>
                      <TextBlock Text="{Binding AccountStatus}" TextWrapping="Wrap">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock" BasedOn="{StaticResource Lumen.Text.BodyStrong}">
                            <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Success}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding AccountStatusIsHealthy}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Error}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Subscription expiry -->
                <Border Grid.Column="2"
                        Background="{StaticResource Lumen.Brush.Control.Rest}"
                        BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                        BorderThickness="{StaticResource Lumen.Stroke.Border}"
                        CornerRadius="{StaticResource Lumen.Radius.Control}"
                        Padding="{StaticResource Lumen.Pad.16}">
                  <StackPanel>
                    <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                               Text="{x:Static res:Strings.Settings_AccountExpiry}"
                               Margin="{StaticResource Lumen.Margin.B8}" />
                    <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                               Text="{Binding ExpiryText}" TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                               Foreground="{StaticResource Lumen.Brush.Accent}"
                               Text="{x:Static res:Strings.Settings_AccountExpiresSoonWarning}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource Lumen.Margin.T4}"
                               Visibility="{Binding ShowExpirySoonWarning, Converter={StaticResource Lumen.BoolToVisibility}}" />
                  </StackPanel>
                </Border>

                <!-- Connections -->
                <Border Grid.Column="4"
                        Background="{StaticResource Lumen.Brush.Control.Rest}"
                        BorderBrush="{StaticResource Lumen.Brush.Stroke.Subtle}"
                        BorderThickness="{StaticResource Lumen.Stroke.Border}"
                        CornerRadius="{StaticResource Lumen.Radius.Control}"
                        Padding="{StaticResource Lumen.Pad.16}">
                  <StackPanel>
                    <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                               Text="{x:Static res:Strings.Settings_AccountConnections}"
                               Margin="{StaticResource Lumen.Margin.B8}" />
                    <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                               Text="{Binding ConnectionsText}" TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                               Text="{Binding ConnectionsAvailableText}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource Lumen.Margin.T4}"
                               Visibility="{Binding ConnectionsAvailableText, Converter={StaticResource Lumen.NullToCollapsed}}" />
                    <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                               Foreground="{StaticResource Lumen.Brush.Error}"
                               Text="{x:Static res:Strings.Settings_AccountAllConnectionsWarning}"
                               TextWrapping="Wrap"
                               Margin="{StaticResource Lumen.Margin.T4}"
                               Visibility="{Binding ShowConnectionsWarning, Converter={StaticResource Lumen.BoolToVisibility}}" />
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Remaining details as a definition list. -->
              <Grid Margin="{StaticResource Lumen.Margin.B12}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                           Text="{x:Static res:Strings.Settings_AccountTrial}" />
                <TextBlock Grid.Column="1" Style="{StaticResource Lumen.Text.Body}" Text="{Binding TrialText}" />
              </Grid>

              <Grid Margin="{StaticResource Lumen.Margin.B12}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                           Text="{x:Static res:Strings.Settings_AccountCreated}" />
                <TextBlock Grid.Column="1" Style="{StaticResource Lumen.Text.Body}" Text="{Binding CreatedText}" />
              </Grid>

              <Grid Margin="{StaticResource Lumen.Margin.B12}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                           Text="{x:Static res:Strings.Settings_AccountFormats}" />
                <TextBlock Grid.Column="1" Style="{StaticResource Lumen.Text.Body}"
                           Text="{Binding AllowedFormatsText}" TextWrapping="Wrap" />
              </Grid>

              <Grid Margin="{StaticResource Lumen.Margin.B16}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                           Text="{x:Static res:Strings.Settings_AccountServerTime}" />
                <TextBlock Grid.Column="1" Style="{StaticResource Lumen.Text.Body}" Text="{Binding ServerTimeText}" />
              </Grid>

              <Button Style="{StaticResource Lumen.Button.Secondary}"
                      Content="{x:Static res:Strings.Common_Refresh}"
                      Command="{Binding RefreshAccountCommand}"
                      HorizontalAlignment="Left" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
