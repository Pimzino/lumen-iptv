<UserControl x:Class="Lumen.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources"
             xmlns:settings="clr-namespace:Lumen.App.Views.Settings">
  <Grid Margin="{StaticResource Lumen.Pad.Page}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Style="{StaticResource Lumen.Text.Display}"
               Text="{x:Static res:Strings.Settings_Title}"
               Margin="{StaticResource Lumen.Margin.B24}" />

    <!-- Initial page-load skeleton (data is fetched on navigation). -->
    <StackPanel Grid.Row="1"
                MaxWidth="760"
                HorizontalAlignment="Left"
                Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
      <ctl:SkeletonBlock Width="140" Height="18" HorizontalAlignment="Left"
                         Margin="{StaticResource Lumen.Margin.B12}" />
      <ctl:SkeletonBlock Height="120" CornerRadius="12" Margin="{StaticResource Lumen.Margin.B32}" />
      <ctl:SkeletonBlock Width="140" Height="18" HorizontalAlignment="Left"
                         Margin="{StaticResource Lumen.Margin.B12}" />
      <ctl:SkeletonBlock Height="160" CornerRadius="12" />
    </StackPanel>

    <!-- Tabbed settings: a fixed sidebar of categories, each hosting one section view. -->
    <TabControl Grid.Row="1"
                Style="{StaticResource Lumen.SettingsTabs}"
                SelectedIndex="{Binding SelectedSectionIndex}"
                Visibility="{Binding IsLoading, Converter={StaticResource Lumen.InverseBoolToVisibility}}">

      <TabItem Tag="{StaticResource Lumen.Icon.Profile}"
               Header="{x:Static res:Strings.SettingsNav_Account}">
        <settings:AccountSettingsSection />
      </TabItem>

      <TabItem Tag="{StaticResource Lumen.Icon.Play}"
               Header="{x:Static res:Strings.SettingsNav_Playback}">
        <settings:PlaybackSettingsSection />
      </TabItem>

      <TabItem Tag="{StaticResource Lumen.Icon.Guide}"
               Header="{x:Static res:Strings.SettingsNav_Guide}">
        <settings:GuideSettingsSection />
      </TabItem>

      <TabItem Tag="{StaticResource Lumen.Icon.Link}"
               AutomationProperties.Name="{x:Static res:Strings.SettingsNav_Integrations}">
        <!-- Header carries a "connected" dot so Trakt status is visible without opening the tab. -->
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{x:Static res:Strings.SettingsNav_Integrations}" VerticalAlignment="Center" />
            <Ellipse Width="7" Height="7"
                     Fill="{StaticResource Lumen.Brush.Success}"
                     VerticalAlignment="Center"
                     Margin="{StaticResource Lumen.Margin.L8}"
                     Visibility="{Binding IsTraktConnected, Converter={StaticResource Lumen.BoolToVisibility}}" />
          </StackPanel>
        </TabItem.Header>
        <settings:IntegrationsSettingsSection />
      </TabItem>

      <TabItem Tag="{StaticResource Lumen.Icon.Storage}"
               Header="{x:Static res:Strings.SettingsNav_Storage}">
        <settings:StorageSettingsSection />
      </TabItem>

      <TabItem Tag="{StaticResource Lumen.Icon.Appearance}"
               Header="{x:Static res:Strings.SettingsNav_Appearance}">
        <settings:AppearanceSettingsSection />
      </TabItem>

      <TabItem Tag="{StaticResource Lumen.Icon.Info}"
               Header="{x:Static res:Strings.SettingsNav_About}">
        <settings:AboutSettingsSection />
      </TabItem>

    </TabControl>

  </Grid>
</UserControl>
