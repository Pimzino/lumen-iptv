<UserControl x:Class="Lumen.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="760"
                HorizontalAlignment="Left"
                Margin="{StaticResource Lumen.Pad.Page}">

      <TextBlock Style="{StaticResource Lumen.Text.Display}"
                 Text="{x:Static res:Strings.Settings_Title}"
                 Margin="{StaticResource Lumen.Margin.B24}" />

      <!-- Loading skeleton (initial page load only) -->
      <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
        <ctl:SkeletonBlock Width="140" Height="18" HorizontalAlignment="Left"
                           Margin="{StaticResource Lumen.Margin.B12}" />
        <ctl:SkeletonBlock Height="120" CornerRadius="12" Margin="{StaticResource Lumen.Margin.B32}" />
        <ctl:SkeletonBlock Width="140" Height="18" HorizontalAlignment="Left"
                           Margin="{StaticResource Lumen.Margin.B12}" />
        <ctl:SkeletonBlock Height="160" CornerRadius="12" Margin="{StaticResource Lumen.Margin.B32}" />
        <ctl:SkeletonBlock Width="140" Height="18" HorizontalAlignment="Left"
                           Margin="{StaticResource Lumen.Margin.B12}" />
        <ctl:SkeletonBlock Height="120" CornerRadius="12" />
      </StackPanel>

      <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource Lumen.InverseBoolToVisibility}}">

      <!-- ============ Profiles ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_Profiles}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B32}">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding Profiles}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="{StaticResource Lumen.Margin.B8}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Border Width="36" Height="36" CornerRadius="18"
                          Background="{Binding AvatarColor}"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding Monogram}"
                               FontFamily="{StaticResource Lumen.Font.Text}"
                               FontSize="{StaticResource Lumen.FontSize.Body}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center"
                              Margin="{StaticResource Lumen.Margin.L12}">
                    <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}" Text="{Binding Name}" />
                    <TextBlock Style="{StaticResource Lumen.Text.Micro}" Text="{Binding KindLabel}" />
                  </StackPanel>
                  <ContentControl Grid.Column="2"
                                  Style="{StaticResource Lumen.Badge.New}"
                                  Content="{x:Static res:Strings.Settings_ProfileActive}"
                                  Margin="{StaticResource Lumen.Margin.R12}"
                                  Visibility="{Binding IsActive, Converter={StaticResource Lumen.BoolToVisibility}}" />
                  <Button Grid.Column="3"
                          Style="{StaticResource Lumen.Button.Ghost}"
                          Content="{x:Static res:Strings.Settings_ProfileSwitch}"
                          Command="{Binding DataContext.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          Margin="{StaticResource Lumen.Margin.R8}"
                          Visibility="{Binding IsActive, Converter={StaticResource Lumen.InverseBoolToVisibility}}" />
                  <Button Grid.Column="4"
                          Style="{StaticResource Lumen.Button.Ghost}"
                          Content="{x:Static res:Strings.Common_Remove}"
                          Command="{Binding DataContext.RemoveProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Button Style="{StaticResource Lumen.Button.Secondary}"
                  Content="{x:Static res:Strings.Shell_AddProfile}"
                  Command="{Binding AddProfileCommand}"
                  HorizontalAlignment="Left"
                  Margin="{StaticResource Lumen.Margin.T8}" />
        </StackPanel>
      </Border>

      <!-- ============ Guide ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_Epg}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B32}">
        <StackPanel>
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{Binding EpgCounts}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
          <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                     Foreground="{StaticResource Lumen.Brush.Accent}"
                     Text="{Binding EpgProgress}"
                     Margin="{StaticResource Lumen.Margin.B12}"
                     Visibility="{Binding EpgProgress, Converter={StaticResource Lumen.NullToCollapsed}}" />
          <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B16}">
            <Button Style="{StaticResource Lumen.Button.Secondary}"
                    Content="{x:Static res:Strings.Settings_EpgRefreshNow}"
                    Command="{Binding RefreshEpgCommand}"
                    IsEnabled="{Binding IsEpgRefreshing, Converter={StaticResource Lumen.InverseBool}}"
                    Margin="{StaticResource Lumen.Margin.R12}" />
            <Button Style="{StaticResource Lumen.Button.Ghost}"
                    Content="{x:Static res:Strings.Settings_CatalogRefreshNow}"
                    Command="{Binding RefreshCatalogCommand}"
                    IsEnabled="{Binding IsCatalogRefreshing, Converter={StaticResource Lumen.InverseBool}}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Lumen.Text.Body}"
                       Text="{x:Static res:Strings.Settings_EpgInterval}"
                       VerticalAlignment="Center"
                       Margin="{StaticResource Lumen.Margin.R16}" />
            <ComboBox Width="200" SelectedIndex="{Binding EpgIntervalIndex}">
              <ComboBoxItem Content="{x:Static res:Strings.Settings_EpgInterval6h}" />
              <ComboBoxItem Content="{x:Static res:Strings.Settings_EpgInterval12h}" />
              <ComboBoxItem Content="{x:Static res:Strings.Settings_EpgInterval24h}" />
              <ComboBoxItem Content="{x:Static res:Strings.Settings_EpgIntervalManual}" />
            </ComboBox>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ============ Channel mapping ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_ChannelMapping}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B32}">
        <StackPanel>
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{Binding MappingSummary}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
          <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                     Text="{x:Static res:Strings.Settings_ChannelMappingBody}"
                     TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B16}"
                     Visibility="{Binding HasUnmappedChannels, Converter={StaticResource Lumen.BoolToVisibility}}" />
          <TextBox Style="{StaticResource Lumen.SearchField}"
                   ctl:LumenUi.Label="{x:Static res:Strings.Filter_ChannelsPlaceholder}"
                   Text="{Binding MappingFilterText, UpdateSourceTrigger=PropertyChanged}"
                   MaxWidth="360"
                   HorizontalAlignment="Left"
                   Margin="{StaticResource Lumen.Margin.B12}"
                   Visibility="{Binding HasUnmappedChannels, Converter={StaticResource Lumen.BoolToVisibility}}"
                   AutomationProperties.Name="{x:Static res:Strings.Filter_ChannelsPlaceholder}" />
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{x:Static res:Strings.Filter_NoMatches}"
                     Margin="{StaticResource Lumen.Margin.B8}"
                     Visibility="{Binding MappingFilterHasNoMatches, Converter={StaticResource Lumen.BoolToVisibility}}" />
          <!-- Virtualized: a large playlist can leave thousands of channels unmatched. Without
               virtualization the ItemsControl realizes a ComboBox per row up front and freezes the
               UI thread. VirtualizingStackPanel + CanContentScroll realizes only the visible rows. -->
          <ItemsControl ItemsSource="{Binding UnmappedChannels}"
                        MaxHeight="360"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ScrollViewer.CanContentScroll="True"
                        Visibility="{Binding HasUnmappedChannels, Converter={StaticResource Lumen.BoolToVisibility}}">
            <ItemsControl.Template>
              <ControlTemplate TargetType="ItemsControl">
                <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                  <ItemsPresenter />
                </ScrollViewer>
              </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="{StaticResource Lumen.Margin.B8}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Style="{StaticResource Lumen.Text.Body}"
                             Text="{Binding Name}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding Options}"
                            SelectedValue="{Binding SelectedXmltvId, Mode=TwoWay}"
                            SelectedValuePath="XmltvId"
                            DisplayMemberPath="Display"
                            ctl:LumenUi.ShowPopupFilter="True"
                            ctl:LumenUi.PopupFilterText="{Binding OptionsFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            AutomationProperties.Name="Guide channel" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- ============ Playback ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_Playback}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B32}">
        <StackPanel>
          <CheckBox Style="{StaticResource Lumen.Toggle}"
                    Content="{x:Static res:Strings.Settings_PreferHls}"
                    IsChecked="{Binding PreferHls}"
                    Margin="{StaticResource Lumen.Margin.B16}" />
          <CheckBox Style="{StaticResource Lumen.Toggle}"
                    Content="{x:Static res:Strings.Settings_HardwareAcceleration}"
                    IsChecked="{Binding HardwareAcceleration}"
                    Margin="{StaticResource Lumen.Margin.B16}" />
          <TextBox Style="{StaticResource Lumen.TextBox}"
                   ctl:LumenUi.Label="{x:Static res:Strings.Settings_StreamUserAgent}"
                   Text="{Binding StreamUserAgent, UpdateSourceTrigger=LostFocus}"
                   HorizontalAlignment="Stretch"
                   Margin="{StaticResource Lumen.Margin.B8}" />
          <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                     Text="{x:Static res:Strings.Settings_StreamUserAgentHint}"
                     TextWrapping="Wrap"
                     Margin="{StaticResource Lumen.Margin.B16}" />
          <StackPanel Orientation="Horizontal">
            <TextBlock Style="{StaticResource Lumen.Text.Body}"
                       Text="{x:Static res:Strings.Settings_ParentalControls}"
                       VerticalAlignment="Center"
                       Margin="{StaticResource Lumen.Margin.R12}" />
            <ContentControl Style="{StaticResource Lumen.Badge.Quality}"
                            Content="{x:Static res:Strings.Common_ComingSoon}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ============ Storage ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_Storage}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B32}">
        <StackPanel>
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{Binding CacheSummary}"
                     Margin="{StaticResource Lumen.Margin.B12}" />
          <Button Style="{StaticResource Lumen.Button.Secondary}"
                  Content="{x:Static res:Strings.Settings_ClearImageCache}"
                  Command="{Binding ClearImageCacheCommand}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- ============ Appearance ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_Theme}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B32}">
        <StackPanel Orientation="Horizontal">
          <ComboBox Width="200" SelectedIndex="0" IsEnabled="False" Margin="{StaticResource Lumen.Margin.R12}">
            <ComboBoxItem Content="{x:Static res:Strings.Settings_ThemeDark}" />
          </ComboBox>
          <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                     VerticalAlignment="Center"
                     Margin="{StaticResource Lumen.Margin.R8}"
                     Text="{x:Static res:Strings.Settings_ThemeLight}" />
          <ContentControl Style="{StaticResource Lumen.Badge.Quality}"
                          Content="{x:Static res:Strings.Common_ComingSoon}"
                          VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- ============ About ============ -->
      <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                 Text="{x:Static res:Strings.Settings_About}"
                 Margin="{StaticResource Lumen.Margin.B12}" />
      <Border Style="{StaticResource Lumen.Card}" Margin="{StaticResource Lumen.Margin.B48}">
        <StackPanel>
          <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                     Text="{Binding VersionLine}"
                     Margin="{StaticResource Lumen.Margin.B8}" />
          <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                     TextWrapping="Wrap"
                     Text="{x:Static res:Strings.Settings_Licenses}" />
        </StackPanel>
      </Border>

      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
