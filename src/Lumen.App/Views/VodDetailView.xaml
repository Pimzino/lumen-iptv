<UserControl x:Class="Lumen.App.Views.VodDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:Lumen.App.Controls"
             xmlns:res="clr-namespace:Lumen.App.Resources"
             xmlns:theming="clr-namespace:Lumen.App.Theming">
  <Grid>
    <!-- Backdrop with scrims -->
    <Image ctl:ImageLoader.Url="{Binding BackdropUrl}"
           ctl:ImageLoader.DecodeWidth="1280"
           Stretch="UniformToFill"
           VerticalAlignment="Top"
           MaxHeight="520"
           Opacity="0.5"
           RenderOptions.BitmapScalingMode="HighQuality" />
    <Border VerticalAlignment="Top" Height="520" Background="{StaticResource Lumen.Brush.Scrim.Top}" />
    <Border VerticalAlignment="Top" Height="520" Background="{StaticResource Lumen.Brush.Scrim.Bottom}" />

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="{StaticResource Lumen.Pad.Page}">

        <Button Style="{StaticResource Lumen.Button.Icon}"
                Content="{StaticResource Lumen.Icon.Back}"
                Command="{Binding BackCommand}"
                HorizontalAlignment="Left"
                Margin="{StaticResource Lumen.Margin.B24}"
                AutomationProperties.Name="{x:Static res:Strings.Common_Back}" />

        <!-- Hero -->
        <Grid Margin="{StaticResource Lumen.Margin.B32}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Width="220"
                  Height="330"
                  CornerRadius="{StaticResource Lumen.Radius.Card}"
                  ClipToBounds="True"
                  Background="{StaticResource Lumen.Brush.Accent.Subtle}"
                  VerticalAlignment="Top">
            <Grid>
              <TextBlock Style="{StaticResource Lumen.Text.Display}"
                         Text="{Binding Title, Converter={StaticResource Lumen.FirstLetter}}"
                         Foreground="{StaticResource Lumen.Brush.Accent}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
              <Image ctl:ImageLoader.Url="{Binding PosterUrl}"
                     ctl:ImageLoader.DecodeWidth="440"
                     Stretch="UniformToFill"
                     RenderOptions.BitmapScalingMode="HighQuality" />
              <!-- Whole-series watched fraction (series only; movies never set it) -->
              <ProgressBar Value="{Binding SeriesProgress, Mode=OneWay}"
                           Maximum="100"
                           VerticalAlignment="Bottom"
                           Margin="10,0,10,10"
                           Visibility="{Binding HasSeriesProgress, Converter={StaticResource Lumen.BoolToVisibility}}" />
            </Grid>
          </Border>

          <StackPanel Grid.Column="1" Margin="{StaticResource Lumen.Margin.L24}" VerticalAlignment="Top">
            <TextBlock Style="{StaticResource Lumen.Text.Display}"
                       Text="{Binding Title}"
                       TextWrapping="Wrap"
                       Margin="{StaticResource Lumen.Margin.B12}" />

            <!-- Loading skeleton: chips + plot while details fetch -->
            <StackPanel HorizontalAlignment="Left"
                        Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
              <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B16}">
                <ctl:SkeletonBlock Width="56" Height="24" CornerRadius="6" Margin="{StaticResource Lumen.Margin.R8}" />
                <ctl:SkeletonBlock Width="72" Height="24" CornerRadius="6" Margin="{StaticResource Lumen.Margin.R8}" />
                <ctl:SkeletonBlock Width="96" Height="24" CornerRadius="6" />
              </StackPanel>
              <ctl:SkeletonBlock Width="620" Height="14" CornerRadius="4" HorizontalAlignment="Left"
                                 Margin="{StaticResource Lumen.Margin.B8}" />
              <ctl:SkeletonBlock Width="580" Height="14" CornerRadius="4" HorizontalAlignment="Left"
                                 Margin="{StaticResource Lumen.Margin.B8}" />
              <ctl:SkeletonBlock Width="420" Height="14" CornerRadius="4" HorizontalAlignment="Left"
                                 Margin="{StaticResource Lumen.Margin.B24}" />
            </StackPanel>

            <WrapPanel Margin="{StaticResource Lumen.Margin.B16}">
              <!-- Watched chip (movies; series watched state lives on the episode cards) -->
              <Border CornerRadius="6"
                      Background="{StaticResource Lumen.Brush.Accent.Subtle}"
                      Padding="8,3"
                      VerticalAlignment="Center"
                      Margin="{StaticResource Lumen.Margin.R8}"
                      Visibility="{Binding WatchedLabel, Converter={StaticResource Lumen.NullToCollapsed}}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{StaticResource Lumen.Icon.Check}"
                             FontFamily="{StaticResource Lumen.Font.Icons}"
                             FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                             Foreground="{StaticResource Lumen.Brush.Accent}"
                             VerticalAlignment="Center"
                             Margin="{StaticResource Lumen.Margin.R8}" />
                  <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                             Foreground="{StaticResource Lumen.Brush.Accent}"
                             Text="{Binding WatchedLabel}"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Border>
              <ItemsControl ItemsSource="{Binding MetadataChips}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <ContentControl Style="{StaticResource Lumen.Badge.Quality}"
                                    Content="{Binding}"
                                    Margin="{StaticResource Lumen.Margin.R8}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </WrapPanel>

            <TextBlock Style="{StaticResource Lumen.Text.Body}"
                       Foreground="{StaticResource Lumen.Brush.Text.Secondary}"
                       Text="{Binding Plot}"
                       TextWrapping="Wrap"
                       MaxWidth="640"
                       HorizontalAlignment="Left"
                       Margin="{StaticResource Lumen.Margin.B16}"
                       Visibility="{Binding Plot, Converter={StaticResource Lumen.NullToCollapsed}}" />

            <!-- Credits -->
            <Grid MaxWidth="640"
                  HorizontalAlignment="Left"
                  Margin="{StaticResource Lumen.Margin.B4}"
                  Visibility="{Binding Cast, Converter={StaticResource Lumen.NullToCollapsed}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                         Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                         Text="{x:Static res:Strings.Vod_CastLabel}"
                         Margin="{StaticResource Lumen.Margin.R12}" />
              <TextBlock Grid.Column="1"
                         Style="{StaticResource Lumen.Text.Caption}"
                         Text="{Binding Cast}"
                         TextWrapping="Wrap" />
            </Grid>
            <Grid MaxWidth="640"
                  HorizontalAlignment="Left"
                  Visibility="{Binding Director, Converter={StaticResource Lumen.NullToCollapsed}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                         Foreground="{StaticResource Lumen.Brush.Text.Tertiary}"
                         Text="{x:Static res:Strings.Vod_DirectorLabel}"
                         Margin="{StaticResource Lumen.Margin.R12}" />
              <TextBlock Grid.Column="1"
                         Style="{StaticResource Lumen.Text.Caption}"
                         Text="{Binding Director}"
                         TextWrapping="Wrap" />
            </Grid>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.T16}">

              <!-- Movie actions -->
              <StackPanel Orientation="Horizontal"
                          Visibility="{Binding IsSeries, Converter={StaticResource Lumen.InverseBoolToVisibility}}">
                <Button Style="{StaticResource Lumen.Button.Primary}"
                        Command="{Binding ResumeCommand}"
                        Margin="{StaticResource Lumen.Margin.R12}"
                        Visibility="{Binding CanResume, Converter={StaticResource Lumen.BoolToVisibility}}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{StaticResource Lumen.Icon.Play}"
                               FontFamily="{StaticResource Lumen.Font.Icons}"
                               FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R8}" />
                    <TextBlock Text="{Binding ResumeLabel}" />
                  </StackPanel>
                </Button>
                <!-- Primary Play when there's nothing to resume -->
                <Button Style="{StaticResource Lumen.Button.Primary}"
                        Command="{Binding PlayCommand}"
                        Margin="{StaticResource Lumen.Margin.R12}"
                        Visibility="{Binding CanResume, Converter={StaticResource Lumen.InverseBoolToVisibility}}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{StaticResource Lumen.Icon.Play}"
                               FontFamily="{StaticResource Lumen.Font.Icons}"
                               FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R8}" />
                    <TextBlock Text="{x:Static res:Strings.Vod_Play}" />
                  </StackPanel>
                </Button>
                <!-- Secondary Start over when a resume point exists -->
                <Button Style="{StaticResource Lumen.Button.Secondary}"
                        Command="{Binding PlayCommand}"
                        Margin="{StaticResource Lumen.Margin.R12}"
                        Content="{x:Static res:Strings.Vod_StartOver}"
                        Visibility="{Binding CanResume, Converter={StaticResource Lumen.BoolToVisibility}}" />
                <!-- Manual watched toggle -->
                <Button Style="{StaticResource Lumen.Button.Ghost}"
                        Command="{Binding ToggleWatchedCommand}"
                        Margin="{StaticResource Lumen.Margin.R12}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Lumen.Font.Icons}"
                               FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                               Text="{StaticResource Lumen.Icon.Check}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R8}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWatched}" Value="True">
                              <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding MarkWatchedLabel}" />
                  </StackPanel>
                </Button>
              </StackPanel>

              <!-- Series action: resume the latest episode or start the next one -->
              <StackPanel Orientation="Horizontal"
                          Visibility="{Binding IsSeries, Converter={StaticResource Lumen.BoolToVisibility}}">
                <Button Style="{StaticResource Lumen.Button.Primary}"
                        Command="{Binding PlaySeriesCommand}"
                        Margin="{StaticResource Lumen.Margin.R12}"
                        Visibility="{Binding HasEpisodes, Converter={StaticResource Lumen.BoolToVisibility}}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{StaticResource Lumen.Icon.Play}"
                               FontFamily="{StaticResource Lumen.Font.Icons}"
                               FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource Lumen.Margin.R8}" />
                    <TextBlock Text="{Binding SeriesPlayLabel}" />
                  </StackPanel>
                </Button>
              </StackPanel>

              <!-- Favorite (both kinds) -->
              <Button Style="{StaticResource Lumen.Button.Ghost}"
                      Command="{Binding ToggleFavoriteCommand}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock FontFamily="{StaticResource Lumen.Font.Icons}"
                             VerticalAlignment="Center"
                             Margin="{StaticResource Lumen.Margin.R8}">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{StaticResource Lumen.Icon.Favorites}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="Text" Value="{StaticResource Lumen.Icon.FavoritesFilled}" />
                            <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Live}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBlock>
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{x:Static res:Strings.Vod_AddFavorite}" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="Text" Value="{x:Static res:Strings.Vod_RemoveFavorite}" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Grid>

        <!-- ============ Series: season tabs + episode cards ============ -->
        <StackPanel MaxWidth="880"
                    HorizontalAlignment="Left"
                    Visibility="{Binding IsSeries, Converter={StaticResource Lumen.BoolToVisibility}}">

          <!-- Header: section title + selected season's episode count + season watched action -->
          <Grid Margin="{StaticResource Lumen.Margin.B12}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource Lumen.Text.Heading}"
                       Text="{x:Static res:Strings.Vod_Episodes}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
              <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                         Text="{Binding SelectedSeason.EpisodeCountLabel}"
                         VerticalAlignment="Center" />
              <Button Command="{Binding MarkSeasonWatchedCommand}"
                      CommandParameter="{Binding SelectedSeason}"
                      Content="{x:Static res:Strings.Vod_MarkSeasonWatched}"
                      Margin="{StaticResource Lumen.Margin.L12}">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource Lumen.Button.Ghost}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding SelectedSeason}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding SelectedSeason.AllWatched}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
            </StackPanel>
          </Grid>

          <!-- Loading: tab-pill and episode-card skeletons -->
          <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource Lumen.BoolToVisibility}}">
            <StackPanel.Resources>
              <!-- One skeleton card, stamped out three times below -->
              <DataTemplate x:Key="EpisodeCardSkeleton">
                <Grid Margin="{StaticResource Lumen.Margin.B16}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <ctl:SkeletonBlock Width="160" Height="90" />
                  <StackPanel Grid.Column="1"
                              Margin="{StaticResource Lumen.Margin.L16}"
                              VerticalAlignment="Center">
                    <ctl:SkeletonBlock Width="260" Height="15" CornerRadius="4" HorizontalAlignment="Left"
                                       Margin="{StaticResource Lumen.Margin.B8}" />
                    <ctl:SkeletonBlock Width="150" Height="11" CornerRadius="4" HorizontalAlignment="Left"
                                       Margin="{StaticResource Lumen.Margin.B8}" />
                    <ctl:SkeletonBlock Width="480" Height="11" CornerRadius="4" HorizontalAlignment="Left" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </StackPanel.Resources>
            <StackPanel Orientation="Horizontal" Margin="{StaticResource Lumen.Margin.B16}">
              <ctl:SkeletonBlock Width="104" Height="38" Margin="{StaticResource Lumen.Margin.R8}" />
              <ctl:SkeletonBlock Width="104" Height="38" Margin="{StaticResource Lumen.Margin.R8}" />
              <ctl:SkeletonBlock Width="104" Height="38" />
            </StackPanel>
            <ContentControl ContentTemplate="{StaticResource EpisodeCardSkeleton}" Focusable="False" IsTabStop="False" />
            <ContentControl ContentTemplate="{StaticResource EpisodeCardSkeleton}" Focusable="False" IsTabStop="False" />
            <ContentControl ContentTemplate="{StaticResource EpisodeCardSkeleton}" Focusable="False" IsTabStop="False" />
          </StackPanel>

          <!-- Season tabs -->
          <ListBox Style="{StaticResource Lumen.TabStrip}"
                   ItemContainerStyle="{StaticResource Lumen.Tab}"
                   ItemsSource="{Binding Seasons}"
                   SelectedItem="{Binding SelectedSeason}"
                   Margin="{StaticResource Lumen.Margin.B8}"
                   Visibility="{Binding HasEpisodes, Converter={StaticResource Lumen.BoolToVisibility}}"
                   AutomationProperties.Name="Seasons">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding Label}" />
                  <TextBlock Text="{Binding WatchedCountLabel}"
                             Opacity="0.65"
                             Margin="{StaticResource Lumen.Margin.L8}"
                             Visibility="{Binding HasWatched, Converter={StaticResource Lumen.BoolToVisibility}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Empty state (M3U series or a provider with no episode data) -->
          <TextBlock Style="{StaticResource Lumen.Text.BodySecondary}"
                     Text="{x:Static res:Strings.Vod_NoEpisodes}"
                     Visibility="{Binding ShowEmptyEpisodes, Converter={StaticResource Lumen.BoolToVisibility}}" />

          <!-- Episodes of the selected season; fades in on tab switch -->
          <ctl:TransitioningContentControl Content="{Binding SelectedSeason}"
                                           Focusable="False"
                                           IsTabStop="False">
            <ctl:TransitioningContentControl.ContentTemplate>
              <DataTemplate>
                <ItemsControl ItemsSource="{Binding Episodes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource Lumen.Button.Ghost}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              Padding="{StaticResource Lumen.Pad.12}"
                              Margin="{StaticResource Lumen.Margin.B4}"
                              Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}"
                              AutomationProperties.Name="{Binding Title}">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>

                          <!-- Thumbnail: image or episode-number monogram, resume bar, hover play -->
                          <Border Width="160"
                                  Height="90"
                                  CornerRadius="{StaticResource Lumen.Radius.Control}"
                                  ClipToBounds="True"
                                  Background="{StaticResource Lumen.Brush.Accent.Subtle}"
                                  VerticalAlignment="Top">
                            <Grid>
                              <TextBlock Style="{StaticResource Lumen.Text.Title}"
                                         Text="{Binding NumberLabel}"
                                         Foreground="{StaticResource Lumen.Brush.Accent}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                              <Image ctl:ImageLoader.Url="{Binding ThumbUrl}"
                                     ctl:ImageLoader.DecodeWidth="320"
                                     Stretch="UniformToFill"
                                     RenderOptions.BitmapScalingMode="HighQuality" />
                              <ProgressBar Value="{Binding ResumeProgress, Mode=OneWay}"
                                           Maximum="100"
                                           VerticalAlignment="Bottom"
                                           Margin="8,0,8,8"
                                           Visibility="{Binding HasResume, Converter={StaticResource Lumen.BoolToVisibility}}" />
                              <Grid Opacity="0" IsHitTestVisible="False">
                                <Grid.Style>
                                  <Style TargetType="Grid">
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   Value="True">
                                        <DataTrigger.EnterActions>
                                          <BeginStoryboard>
                                            <Storyboard>
                                              <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="1"
                                                               Duration="{theming:Dur Fast}">
                                                <DoubleAnimation.EasingFunction>
                                                  <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                              </DoubleAnimation>
                                            </Storyboard>
                                          </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                          <BeginStoryboard>
                                            <Storyboard>
                                              <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                               To="0"
                                                               Duration="{theming:Dur Fast}">
                                                <DoubleAnimation.EasingFunction>
                                                  <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                              </DoubleAnimation>
                                            </Storyboard>
                                          </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Grid.Style>
                                <Border Background="{StaticResource Lumen.Brush.Scrim}" />
                                <Border Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Background="{StaticResource Lumen.Brush.Accent}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                  <TextBlock Text="{StaticResource Lumen.Icon.Play}"
                                             FontFamily="{StaticResource Lumen.Font.Icons}"
                                             FontSize="{StaticResource Lumen.FontSize.Icon}"
                                             Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Border>
                              </Grid>
                              <!-- Watched tick (kept above the hover scrim) -->
                              <Border Width="22"
                                      Height="22"
                                      CornerRadius="11"
                                      Background="{StaticResource Lumen.Brush.Accent}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Margin="0,6,6,0"
                                      Visibility="{Binding IsWatched, Converter={StaticResource Lumen.BoolToVisibility}}">
                                <TextBlock Text="{StaticResource Lumen.Icon.Check}"
                                           FontFamily="{StaticResource Lumen.Font.Icons}"
                                           FontSize="{StaticResource Lumen.FontSize.IconSmall}"
                                           Foreground="{StaticResource Lumen.Brush.Text.OnAccent}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                              </Border>
                            </Grid>
                          </Border>

                          <!-- Title, meta, plot (dimmed once watched) -->
                          <StackPanel Grid.Column="1"
                                      Margin="{StaticResource Lumen.Margin.L16}"
                                      VerticalAlignment="Center">
                            <StackPanel.Style>
                              <Style TargetType="StackPanel">
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                    <Setter Property="Opacity" Value="0.6" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </StackPanel.Style>
                            <TextBlock Style="{StaticResource Lumen.Text.BodyStrong}"
                                       Text="{Binding Title}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource Lumen.Text.Micro}"
                                       Text="{Binding MetaLine}"
                                       Margin="{StaticResource Lumen.Margin.T4}"
                                       Visibility="{Binding MetaLine, Converter={StaticResource Lumen.NullToCollapsed}}" />
                            <TextBlock Style="{StaticResource Lumen.Text.Caption}"
                                       Text="{Binding Plot}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="40"
                                       Margin="{StaticResource Lumen.Margin.T4}"
                                       Visibility="{Binding Plot, Converter={StaticResource Lumen.NullToCollapsed}}" />
                          </StackPanel>

                          <!-- Watched toggle: muted until hovered or already watched -->
                          <Button Grid.Column="2"
                                  Command="{Binding DataContext.ToggleEpisodeWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"
                                  ToolTip="{Binding WatchedToggleTooltip}"
                                  VerticalAlignment="Center"
                                  Margin="{StaticResource Lumen.Margin.L12}"
                                  AutomationProperties.Name="{Binding WatchedToggleTooltip}">
                            <Button.Style>
                              <Style TargetType="Button" BasedOn="{StaticResource Lumen.Button.Icon}">
                                <Setter Property="Opacity" Value="0.45" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                  </DataTrigger>
                                  <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                  </Trigger>
                                </Style.Triggers>
                              </Style>
                            </Button.Style>
                            <TextBlock Text="{StaticResource Lumen.Icon.Check}"
                                       FontFamily="{StaticResource Lumen.Font.Icons}"
                                       FontSize="{StaticResource Lumen.FontSize.IconSmall}">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                      <Setter Property="Foreground" Value="{StaticResource Lumen.Brush.Accent}" />
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>
                          </Button>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </DataTemplate>
            </ctl:TransitioningContentControl.ContentTemplate>
          </ctl:TransitioningContentControl>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
